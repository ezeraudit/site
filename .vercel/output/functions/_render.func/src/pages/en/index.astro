---
import Layout from "../../layouts/Layout.astro";
import HeroHome from "../../components/HeroHome.astro";
import TextMarquee from "../../components/TextMarquee.astro";
import GalleryText from "../../components/GalleryText.astro";
import ImageMarquee from "../../components/ImageMarquee.astro";
import Faqs from "../../components/Faqs.astro";
import StepsTimeline from "../../components/StepsTimeline.astro";
import Plans from "../../components/Plans.astro";
import Statements from "../../components/Statements.astro";
import Introducing from "../../components/Introducing.astro";
import GL from "../../components/GL.astro";
import GLPlaces from "../../components/GlPlaces.astro";

import logo1 from "../../assets/astro_transparent.png";
import logo2 from "../../assets/azure_transparent.png";
import logo3 from "../../assets/bailian_transparent.png";
import logo4 from "../../assets/cloudflare_transparent.png";
import logo5 from "../../assets/eastmoney_transparent.png";
import logo6 from "../../assets/github_transparent.png";
import logo7 from "../../assets/huggingface_transparent.png";
import logo8 from "../../assets/hugo_transparent.png";
import logo9 from "../../assets/openclaw_transparent.png";
import logo10 from "../../assets/spaceship_transparent.png";
import logo11 from "../../assets/supabase_transparent.png";
import logo12 from "../../assets/vercel_transparent.png";
---

<Layout title="Ezer - Adversarial Audit-Grade Financial Analysis System">
  <HeroHome
    title="Adversarial Audit-Grade Fin.Analysis"
    subtitle="Ezer systematizes professional research workflows, streamlining 'Parsing - Policing - Verification - Review - Generation' to help you pinpoint real risks instantly."
    cta={{
      title: "Get Started",
      url: "/en/search/",
    }}
  />

  <Introducing
    title="Not just a chatbot, but a professional analysis system for everyone"
    text="Addressing high barriers to entry and unreliable AI models, Ezer pioneers the Red-Blue adversarial logic. The Red Team uncovers risks while the Blue Team verifies them, solving the 'black box' unreliability of general-purpose models."
    cta={{
      title: "Start Analysis",
      url: "/en/search/",
    }}
  />

  <StepsTimeline
    title="3 Steps to Professional Financial Analysis"
    items={[
      {
        title: "One-Click Input",
        text: "Enter a company name or code. The system automatically fetches and parses lengthy, complex financial reports in seconds.",
      },
      {
        title: "Adversarial AI Analysis",
        text: "Our proprietary orchestration hub drives multi-agents for red-blue cross-verification, maximizing risk coverage and analysis accuracy.",
      },
      {
        title: "Structured Report Output",
        text: "Get automated reports with risk levels, evidence chains, and review suggestions—all fully visualized and traceable.",
      },
    ]}
  />

  <GalleryText
    title="Built for 150 Million Modern Investors"
    text="Behind a clean interface lies a highly complex orchestration hub. We lower the barrier to financial research, providing professional-grade investment analysis for everyone."
    cta={{
      title: "View Demo",
      url: "/en/check/",
    }}
    images={[
      {
        alt: "Risk Detection Interface",
        src: "/image-1.jpg",
        width: 6000,
        height: 4000,
      },
      {
        alt: "Red-Blue Adversarial Logic",
        src: "/image-2.jpg",
        width: 2689,
        height: 4032,
      },
      {
        alt: "Structured Analysis Report",
        src: "/image-3.jpg",
        width: 3734,
        height: 5359,
      },
    ]}
    marqueeTexts={[
      "Red-Blue Adversarial",
      "Verifiable Results",
      "Multi-Agent Collaboration",
      "Complete Evidence Chain",
    ]}
  />

  <Statements
    items={[
      {
        title: "Modular Architecture",
        text: "Proprietary orchestration + multi-agent clusters. Independent modules iterate precisely for complex auditing scenarios.",
      },
      {
        title: "Cross-Verification Process",
        text: "Industry-first Red-Blue split. Logical counter-proofing significantly reduces misjudgment and AI hallucinations.",
      },
      {
        title: "Sustainable Business Model",
        text: "Multi-model routing optimizes costs, ensuring B2B profitability and accessible B2C premium services.",
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "Red-Blue Adversarial",
      "Verifiable Results",
      "Multi-Agent Collaboration",
      "Complete Evidence Chain",
    ]}
  />

  <Plans
    title="Plans & Pricing"
    subtitle="Start for free, upgrade for in-depth research. No hidden fees, no long-term commitments."
    items={[
      {
        title: "Free Plan",
        price: {
          amount: "$0",
          duration: "month",
        },
        link: {
          title: "Start for Free",
          url: "/en/check/",
        },
        features: [
          { title: "Basic Financial Parsing" },
          { title: "Standard Adversarial Analysis" },
          { title: "Community Support", disabled: true },
          { title: "Multi-Company Comparison", disabled: true },
          { title: "Professional PDF Export", disabled: true },
        ],
      },
      {
        title: "Premium Plan",
        price: {
          amount: "$3",
          duration: "month",
        },
        link: {
          title: "Get Started",
          url: "#",
        },
        features: [
          { title: "High-Volume Analysis Calls" },
          { title: "One-Click Indicator Comparison" },
          { title: "Professional PDF Export" },
          { title: "Custom Analysis Focus" },
          { title: "Exclusive B2B API Access" },
        ],
      },
    ]}
  />

  <Faqs
    title="Frequently Asked Questions"
    mobileTitle="FAQs"
    subtitle="Quick answers to common questions about Ezer."
    items={[
      {
        question: "How is Ezer different from generic AI like ChatGPT?",
        answer:
          "Generic models lack stable research processes and are prone to hallucinations. Ezer emphasizes orchestration, verification, and evidence chains, making results traceable and reliable.",
      },
      {
        question: "What is the Red-Blue Adversarial mechanism?",
        answer:
          "It's an industry-first logic: the Red Team uncovers anomalies, while the Blue Team handles counter-verification. This cross-check significantly reduces misjudgment.",
      },
      {
        question: "Who are Ezer's core users?",
        answer:
          "We serve two groups: individual investors who want in-depth financial research, and B2B clients like brokerages and investment platforms.",
      },
      {
        question: "Can beginners understand the analysis results?",
        answer:
          "Yes. Our goal is to lower the barrier by converting complex jargon into structured reports with clear risk levels and clear evidence.",
      },
      {
        question: "What is the current project status?",
        answer:
          "We have completed MVP development. The entire workflow—from report upload to intelligent analysis and generation—is fully operational.",
      },
    ]}
  />

  <ImageMarquee
    images={[
      {
        src: logo1.src,
        alt: "Logo 1",
      },
      {
        src: logo2.src,
        alt: "Logo 2",
      },
      {
        src: logo3.src,
        alt: "Logo 3",
      },
      {
        src: logo4.src,
        alt: "Logo 4",
      },
      {
        src: logo5.src,
        alt: "Logo 5",
      },
      {
        src: logo6.src,
        alt: "Logo 6",
      },
      {
        src: logo7.src,
        alt: "Logo 7",
      },
      {
        src: logo8.src,
        alt: "Logo 8",
      },
      {
        src: logo9.src,
        alt: "Logo 9",
      },
      {
        src: logo10.src,
        alt: "Logo 10",
      },
      {
        src: logo11.src,
        alt: "Logo 11",
      },
      {
        src: logo12.src,
        alt: "Logo 12",
      },
    ]}
  />

  <GL />
  <GLPlaces />
</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>