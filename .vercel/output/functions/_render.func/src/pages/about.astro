---
import Layout from "../layouts/Layout.astro";
import TextMarquee from "../components/TextMarquee.astro";
import Button from "../components/Button.astro";

const values = [
  {
    title: "红蓝对抗",
    text: "行业首创对抗式验证逻辑：红队挖掘疑点，蓝队反证校验，有效降低模型幻觉与误判风险。",
  },
  {
    title: "证据可溯",
    text: "拒绝“黑盒输出”。我们强调分析结果的确定性与可追溯性，每一项结论都有完整的证据链条支撑。",
  },
  {
    title: "专业平民化",
    text: "我们致力于消除专业审计与普通投资者之间的鸿沟，将顶级投研人员的工作流标准化、产品化。",
  },
  {
    title: "高效协同",
    text: "利用自研编排中枢驱动多智能体集群并行处理，覆盖财报全维度，实现分析效率的量级提升。",
  },
];
---

<Layout title="关于 Ezer - 重新定义财报分析">
  <section class="intro">
    <div class="u-container">
      <h1 class="u-heading large-title" data-sy-reveal="blurIn">
        重新定义<span class="brand-color">财报研究</span>的未来
      </h1>
      <p class="u-text intro-text" data-sy-reveal="slideUp">
        我们是理性敏锐、交叉创新的金融科技新锐。通过将红蓝对抗机制引入财报审计，我们旨在赋能 1.5 亿泛投资人群，以专家级视野重构财报分析体验，直击数据背后的真实价值
      </p>
    </div>
  </section>

  <section class="story">
    <div id="story-canvas" class="story-canvas"></div>
    <div class="u-container">
      <div class="u-row align-items-center">
        <div class="u-col-6 u-col-md-12 story-content">
          <h2 class="u-heading section-title" data-sy-reveal="words">我们的使命</h2>
          <div class="u-text story-text" data-sy-reveal="fade">
            <p>
              面对长篇累牍的术语与真假难辨的数据，普通投资者在财报研究中长期处于劣势。Ezer的使命是消除专业投研门槛，让真相不再被臃肿的信息掩盖。
            </p>
            <p>
              通过全流程闭环逻辑，我们实现了从 "信息提取" 到 "深度审计" 的范式跨越。Ezer 拒绝流于表面的内容概括，而是通过严苛的对抗验证，让投资风险由虚转实，有据可依
            </p>
          </div>
        </div>
        <div class="u-col-6 u-col-md-12" data-sy-reveal="scaleUp">
          <div class="image-placeholder">
            <img src="/image-1.jpg" alt="Ezer 智能分析场景" class="story-image" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="values">
    <div class="u-container">
      <h2 class="u-heading section-title center" data-sy-reveal="blurIn">核心技术理念</h2>
      <div class="u-row">
        {values.map((value, i) => (
          <div class="u-col-3 u-col-md-6 u-col-sm-12">
            <div class="value-card" data-sy-reveal="slideUp" style={`--d: ${i * 0.1}s`}>
              <h3 class="u-heading card-title">{value.title}</h3>
              <p class="u-text card-text">{value.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="marquee-section">
    <TextMarquee
      class="about-marquee"
      texts={[
        "对抗验证",
        "拒绝幻觉",
        "证据可循",
        "赋能投资者",
      ]}
    />
  </section>

  <section class="cta-section" id="cta-section">
    <canvas id="cta-cursor-canvas" class="cta-cursor-canvas"></canvas>
    <div class="u-container">
      <div class="cta-box" data-sy-reveal="scaleUp">
        <h2 class="u-heading cta-title" data-sy-reveal="blurIn">开启您的专业分析之旅。</h2>
        <p class="u-text cta-subtitle" data-sy-reveal="slideUp">告别低效的人工翻阅，用红蓝对抗机制锁定真正的投资风险。</p>
        <Button title="立即体验 Ezer" url="#" arrow />
      </div>
    </div>
  </section>
</Layout>

<style>
  /* 样式部分保持不变 */
  section {
    padding: 8rem 0;
  }

  .align-items-center {
    align-items: center;
  }

  /* Intro Section */
  .intro {
    padding-top: 12rem;
    text-align: center;
  }

  .large-title {
    --fs: 5rem;
    --lh: 1.3;
    max-width: 15em;
    margin: 0 auto 2rem;

    @media (--mq-phone) {
      --fs: 3rem;
    }
  }

  .brand-color {
    color: var(--color-brand-1);
  }

  .intro-text {
    --fs: 1.5rem;
    --lh: 1.6;
    max-width: 35em;
    margin: 0 auto;
    opacity: 0.8;

    @media (--mq-phone) {
      --fs: 1.2rem;
    }
  }

  /* Story Section */
  .story {
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .story-canvas {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  .story-content {
    @media (--mq-tablet) {
      margin-bottom: 3rem;
      text-align: center;
    }
  }

  .section-title {
    --fs: 3rem;
    margin-bottom: 2rem;

    @media (--mq-phone) {
      --fs: 2.25rem;
    }
  }

  .center {
    text-align: center;
    margin-bottom: 4rem;
  }

  .story-text p {
    margin-bottom: 1.5rem;
  }

  .image-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--color-brand-3);
    border-radius: 2rem;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .story-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 1rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    transition: transform 0.5s var(--ease-out-expo);

    &:hover {
      transform: scale(1.02);
    }
  }

  .image-placeholder::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(var(--rgb-brand-1), 0.1), transparent);
  }

  /* Values Section */
  .value-card {
    height: 100%;
    padding: 3rem;
    background: rgba(var(--rgb-white), 0.5);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(var(--rgb-brand-1), 0.1);
    border-radius: 1.5rem;
    transition: transform 0.3s var(--ease-out-expo), border-color 0.3s;
    animation-delay: var(--d);

    :global([data-theme="dark"]) & {
      background: rgba(30, 30, 36, 0.5);
      border-color: rgba(var(--rgb-brand-1), 0.2);
    }

    &:hover {
      transform: translateY(-0.5rem);
      border-color: var(--color-brand-1);
    }
  }

  .card-title {
    --fs: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-brand-1);
  }

  .card-text {
    --fs: var(--font-size-sm);
  }

  /* Marquee Section */
  .marquee-section {
    padding: 4rem 0;
    background: var(--color-brand-1);
    color: var(--color-brand-3);
  }

  .about-marquee {
    --c: var(--color-brand-3);
  }

  /* CTA Section */
  .cta-section {
    position: relative;
    overflow: hidden;
    text-align: center;
    z-index: 1;
    min-height: 400px; /* fallback height */
  }

  .cta-cursor-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    width: 100% !important;
    height: 100% !important;
  }

  .cta-box {
    position: relative;
    z-index: 1;
    background: rgba(var(--rgb-brand-3), 0.3);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(var(--rgb-white), 0.1);
    padding: 6rem 2rem;
    
    :global([data-theme="dark"]) & {
      background: rgba(236, 231, 253, 0.3);
    }
    border-radius: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .cta-title {
    --fs: 4rem;
    margin-bottom: 0.5rem;
    color: var(--color-white);

    @media (--mq-phone) {
      --fs: 2.5rem;
    }
  }

  .cta-subtitle {
    --fs: 1.25rem;
    max-width: 30em;
    color: var(--color-white);
    opacity: 0.8;
    margin-bottom: 1rem;

    @media (--mq-phone) {
      --fs: 1rem;
    }
  }
</style>

<script>
  /* 脚本部分保持不变 */
  import * as THREE from 'three';

  function initStoryBackground() {
    const container = document.getElementById('story-canvas');
    if (!container) return;

    container.innerHTML = '';

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight || 1, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    const group = new THREE.Group();
    scene.add(group);

    const geometry = new THREE.IcosahedronGeometry(1, 15);
    const material = new THREE.MeshPhysicalMaterial({
      color: 0x8d73f5,
      metalness: 0,
      roughness: 0.2,
      transmission: 0.8,
      thickness: 0.5,
      transparent: true,
      opacity: 0.3,
    });

    const particles = [];
    for (let i = 0; i < 4; i++) {
      const mesh = new THREE.Mesh(geometry, material.clone());
      const scale = 0.5 + Math.random() * 1.5;
      mesh.scale.set(scale, scale, scale);
      mesh.position.set(
        (Math.random() - 0.5) * 10,
        (Math.random() - 0.5) * 6,
        (Math.random() - 0.5) * 4
      );
      
      const colors = [0x8d73f5, 0xec77fd, 0x8caf31];
      mesh.material.color.set(colors[Math.floor(Math.random() * colors.length)]);
      
      group.add(mesh);
      particles.push(mesh);
    }

    const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
    scene.add(ambientLight);

    const pointLight = new THREE.PointLight(0xffffff, 1);
    pointLight.position.set(5, 5, 5);
    scene.add(pointLight);

    camera.position.z = 8;

    function animate() {
      requestAnimationFrame(animate);
      
      particles.forEach((p, i) => {
        p.rotation.x += 0.0005 * (i % 2 === 0 ? 1 : -1);
        p.rotation.y += 0.0008 * (i % 3 === 0 ? 1 : -1);
        p.position.y += Math.sin(Date.now() * 0.0005 + i) * 0.001;
        p.position.x += Math.cos(Date.now() * 0.0005 + i) * 0.001;
      });

      group.rotation.y = Math.sin(Date.now() * 0.0001) * 0.03;
      group.rotation.x = Math.cos(Date.now() * 0.0001) * 0.03;

      renderer.render(scene, camera);
    }

    animate();

    window.addEventListener('resize', () => {
      camera.aspect = container.clientWidth / container.clientHeight || 1;
      camera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    });
  }

  function init() {
    setTimeout(() => {
      initStoryBackground();
    }, 100);
  }

  if (document.readyState === 'complete') {
    init();
  } else {
    window.addEventListener('load', init);
  }

  document.addEventListener('astro:page-load', init);
</script>

<script is:inline type="module">
  import TubesCursor from "https://cdn.jsdelivr.net/npm/threejs-components@0.0.19/build/cursors/tubes1.min.js"

  function initCTA() {
    const el = document.getElementById('cta-cursor-canvas')
    if (!el) return

    const app = TubesCursor(el, {
      tubes: {
        colors: ["#f967fb", "#53bc28", "#6958d5"],
        lights: {
          intensity: 200,
          colors: ["#83f36e", "#fe8a2e", "#ff008a", "#60aed5"]
        }
      }
    })

    el.addEventListener('click', () => {
      const colors = randomColors(3)
      const lightsColors = randomColors(4)
      app.tubes.setColors(colors)
      app.tubes.setLightsColors(lightsColors)
    })
  }

  function randomColors (count) {
    return new Array(count)
        .fill(0)
        .map(() => "#" + Math.floor(Math.random() * 16777215).toString(16).padStart(6, '0'))
  }

  if (document.readyState === 'complete') {
    initCTA()
  } else {
    window.addEventListener('load', initCTA)
  }

  document.addEventListener('astro:page-load', initCTA)
</script>