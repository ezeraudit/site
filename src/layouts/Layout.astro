---
import { Font } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import { pwaInfo } from "virtual:pwa-info";

const { title, description, keywords } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const metaDescription = description || t("seo.default_description");
const metaKeywords = keywords; // No default fallback here

const links = [
  { title: t("nav.home"), url: lang === 'zh' ? '/' : '/en/' },
  { title: t("nav.about"), url: lang === 'zh' ? '/about/' : '/en/about/' },
  { title: t("nav.search"), url: lang === 'zh' ? '/search/' : '/en/search/' },
];

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/en' || Astro.url.pathname === '/en/';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    {metaKeywords && <meta name="keywords" content={metaKeywords} />}
    <link href="https://fonts.cat.net/css2?family=Noto+Sans+SC:wght@100..900&family=Noto+Serif+SC:wght@200..900&family=Roboto+Slab:wght@100..900&family=Roboto:wght@100..900&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/pwa-192x192.png" />
    <meta name="theme-color" content="#000000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    { lang === 'en' ? <link rel="manifest" href="/manifest-en.webmanifest" /> : (pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />) }
    <title>{isHome ? (title ? `${t("site.name")} - ${title}` : t("site.name")) : (title ? `${title} - ${t("site.name")}` : t("site.name"))}</title>
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
      window.localStorage.setItem('theme', theme);
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6365WW8WFY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-6365WW8WFY');
    </script>
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "w9d1vhn46l");
    </script>
    <script is:inline>
      var _hmt = _hmt || [];
      (function() {
        var hm = document.createElement("script");
        hm.src = "https://hm.baidu.com/hm.js?9c6bb5a42f15083a6fcd3595c20a1870";
        var s = document.getElementsByTagName("script")[0]; 
        s.parentNode.insertBefore(hm, s);
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">{t("accessibility.skip-to-content")}</a>
    <Header
      logoUrl={lang === 'zh' ? '/' : '/en/'}
      logoAlt={t("site.name")}
      links={links}
      link2={{ title: t("nav.signin"), url: "#" }}
    >
      <div slot="after-nav" style="display: flex; align-items: center; gap: 0.8rem;">
        <LanguageSwitcher />
        <ThemeToggle />
      </div>
    </Header>
    <main id="main">
      <slot />
    </main>
    <Footer logoUrl={lang === 'zh' ? '/' : '/en/'} logoAlt={t("footer.logoAlt")} links={links} />
    <SmoothScroll />
  </body>
</html>

<style>
  .skip-link {
    background: var(--color-brand-1);
    left: 0;
    right: 0;
    margin: auto;
    width: min-content;
    white-space: nowrap;
    padding: 0.5rem;
    position: absolute;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0%);
  }
</style>

<script>
  import "../utils/reveals";
  import "../scripts/auth.js";

  // PWA registration
  import { registerSW } from 'virtual:pwa-register';
  registerSW({ 
    immediate: true,
    onRegistered(r) {
      console.log('SW Registered:', r);
    },
    onRegisterError(error) {
      console.error('SW Registration Error:', error);
    }
  });
</script>
