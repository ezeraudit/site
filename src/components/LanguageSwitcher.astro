---
import { getLangFromUrl, getLocalizedPathname } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const currentLabel = lang === "zh" ? "简体中文" : "English";

const languages = [
  { code: "zh", label: "简体中文" },
  { code: "en", label: "English" }
];

const options = languages.map(l => ({
  ...l,
  path: getLocalizedPathname(Astro.url, l.code),
  active: l.code === lang
}));
---

<div class="language-switcher" id="lang-switcher">
  <button class="lang-toggle" aria-haspopup="true" aria-expanded="false">
    <span class="icon">🌐</span>
    <span class="label">{currentLabel}</span>
    <svg class="arrow" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <div class="dropdown">
    <ul class="dropdown-list">
      {options.map(opt => (
        <li class="dropdown-item">
          <a href={opt.path} class:list={["dropdown-link", { active: opt.active }]}>
            {opt.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .language-switcher {
    position: relative;
    display: inline-block;
    z-index: 10;
  }

  .lang-toggle {
    @extend %u-text;
    --fs: var(--font-size-xs);
    --fw: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.2rem;
    border-radius: 100px;
    background: var(--color-brand-3);
    color: var(--color-text);
    border: 2px solid var(--color-brand-3);
    cursor: pointer;
    transition: all 0.3s var(--ease-out-expo);
    line-height: 1.2;
  }

  .lang-toggle:hover {
    background: var(--color-white);
    border-color: var(--color-brand-1);
    color: var(--color-brand-1);
  }

  .icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .arrow {
    transition: transform 0.3s var(--ease-out-expo);
    opacity: 0.8;
  }

  .language-switcher:hover .arrow,
  .language-switcher.is-open .arrow {
    transform: rotate(180deg);
  }

  /* Dropdown Styles */
  .dropdown {
    position: absolute;
    top: calc(100% + 0.6rem);
    right: 0;
    min-width: 160px;
    background: var(--color-surface-translucent);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(var(--rgb-brand-1), 0.15);
    border-radius: 1rem;
    box-shadow: 0 15px 35px -5px rgba(0, 0, 0, 0.1), 
                0 10px 15px -6px rgba(0, 0, 0, 0.05);
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s var(--ease-out-expo);
    z-index: 100;
  }

  .language-switcher:hover .dropdown,
  .language-switcher.is-open .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-list {
    list-style: none !important;
    list-style-type: none !important;
    padding: 0.5rem !important;
    margin: 0 !important;
  }

  .dropdown-item {
    margin: 0 !important;
    list-style: none !important;
    display: block !important;
  }

  .dropdown-link {
    display: block;
    padding: 0.7rem 1rem;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .dropdown-link:hover {
    background: rgba(var(--rgb-brand-1), 0.08);
    color: var(--color-brand-1);
  }

  .dropdown-link.active {
    background: rgba(var(--rgb-brand-1), 0.12);
    color: var(--color-brand-1);
    font-weight: 700;
  }

  @media (--mq-phone) {
    .label {
      display: none;
    }
    .lang-toggle {
      padding: 0.5rem 0.5rem;
      gap: 0.2rem;
    }
    .dropdown {
      right: -0.5rem;
    }
  }

  @media (--mq-tablet) {
    .lang-toggle {
      padding: 0.6rem 0.8rem;
    }
  }
</style>

<script>
  const switcher = document.getElementById('lang-switcher');
  const toggle = switcher?.querySelector('.lang-toggle');

  if (switcher && toggle) {
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      switcher.classList.toggle('is-open');
      const expanded = switcher.classList.contains('is-open');
      toggle.setAttribute('aria-expanded', expanded.toString());
    });

    // Close when clicking outside
    document.addEventListener('click', () => {
      switcher.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
    });
  }
</script>
