---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { ui } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translations = ui[lang];

// Check parameters
const code = Astro.url.searchParams.get('code');
const year = Astro.url.searchParams.get('year');
const period = Astro.url.searchParams.get('period');
const preview = Astro.url.searchParams.get('preview');

// 1. No parameters -> Redirect to search
if (!code && !year && !period && !preview) {
  return Astro.redirect(lang === 'zh' ? '/search/' : '/en/search/');
}

// 2. Auth check if not preview
if (preview !== 'true') {
  const cookies = Astro.request.headers.get('cookie') || '';
  const hasSession = cookies.includes('sb-msufgvqofnihylcnxyac-auth-token');
  
  if (!hasSession) {
    const loginUrl = `https://account.ezer.cc/${lang === 'en' ? 'en/' : ''}login/?redirect=${encodeURIComponent(Astro.url.href)}`;
    return Astro.redirect(loginUrl);
  }
}
---

<!-- Injected i18n for client-side script -->
<meta name="check-i18n" content={JSON.stringify(translations)} />

<Layout title={t("check.title")}>
  <div class="check-page">
    <div class="u-container">
      <!-- Page Header -->
      <div class="check-header">
        <h1 class="check-title" id="page-title">{t("check.title")}</h1>
      </div>

      <!-- Loading State -->
      <div class="loading-container" id="loading-container">
        <div class="spinner-wrapper">
          <div class="spinner"></div>
          <div class="spinner-ring"></div>
        </div>
        <p class="loading-text" id="loading-text">{t("check.loading")}</p>
        <div class="progress-bar-wrapper">
          <div class="progress-bar" id="progress-bar"></div>
        </div>
        <p class="progress-label" id="progress-label">0%</p>
      </div>

      <!-- Error State -->
      <div class="error-container hidden" id="error-container">
        <div class="error-icon">⚠️</div>
        <p class="error-text" id="error-text">{t("check.error")}</p>
        <a id="back-link" href={lang === "zh" ? "/search" : "/en/search"} class="back-btn">
          ← {lang === "zh" ? "返回搜索" : "Back to Search"}
        </a>
      </div>

      <!-- Results -->
      <div class="results-container hidden" id="results-container">
        <!-- Thought Process (A, B, C) -->
        <div class="thought-container" id="thought-container">
          <button class="thought-header" id="thought-toggle" aria-expanded="true">
            <span class="thought-icon">📊</span>
            <span class="thought-title">{t("check.thought")}</span>
            <span class="thought-arrow"></span>
          </button>
          
          <div class="thought-content" id="thought-content">
            <div class="thought-grid">
              <!-- A: Structured Data -->
              <div class="thought-section section-a hidden">
                <div class="section-label">数据归一化 (A)</div>
                <div class="charts-grid" id="charts-a">
                  <div class="chart-item">
                    <div class="chart-label">营业收入 (Revenue)</div>
                    <div class="chart-canvas-wrapper">
                      <canvas id="chart-revenue"></canvas>
                    </div>
                  </div>
                  <div class="chart-item">
                    <div class="chart-label">净利润 (Net Profit)</div>
                    <div class="chart-canvas-wrapper">
                      <canvas id="chart-profit"></canvas>
                    </div>
                  </div>
                  <div class="chart-item">
                    <div class="chart-label">毛利率 (Gross Margin)</div>
                    <div class="chart-canvas-wrapper">
                      <canvas id="chart-margin"></canvas>
                    </div>
                  </div>
                  <div class="chart-item">
                    <div class="chart-label">资产负债率 (Debt Ratio)</div>
                    <div class="chart-canvas-wrapper">
                      <canvas id="chart-debt"></canvas>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- B: Analysis Text -->
              <div class="thought-section section-b">
                <div class="section-label">深度分析 (B)</div>
                <div class="scroll-wrapper-b">
                  <div class="text-output" id="text-b"></div>
                </div>
              </div>
              
              <!-- C: Auditor Text -->
              <div class="thought-section section-c">
                <div class="section-label">风险审计 (C)</div>
                <div class="scroll-wrapper-b">
                  <div class="text-output" id="text-c"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Summary Section -->
        <div class="summary-container" id="summary-section-container">
          <h2 class="col-title">{t("check.headline")}</h2>
          <div class="summary-box">
            <div id="summary-text" class="text-output"></div>
            <div id="final-result-text" class="final-result-output hidden"></div>
          </div>
        </div>
        
        <!-- Preview CTA Button -->
        <div id="preview-cta-container" class="preview-cta-container hidden">
          <a href={lang === 'zh' ? '/search/' : '/en/search/'} class="cta-button">
            {lang === 'zh' ? '立即开启正式分析' : 'Start Full Analysis Now'}
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .check-page {
    min-height: 100vh;
    padding: 10vh 1rem 4rem;
    background: var(--color-bg);
  }

  /* ── Header ── */
  .check-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .check-title {
    font-family: var(--font-roboto-slab);
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    color: var(--color-text);
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  /* ── Loading ── */
  .loading-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    padding: 4rem 1rem;
  }

  .spinner-wrapper {
    position: relative;
    width: 64px;
    height: 64px;
  }

  .spinner {
    width: 64px;
    height: 64px;
    border: 3px solid rgba(var(--rgb-brand-1), 0.15);
    border-top-color: var(--color-brand-1);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .spinner-ring {
    position: absolute;
    inset: 6px;
    border: 2px solid rgba(var(--rgb-brand-1), 0.08);
    border-bottom-color: rgba(var(--rgb-brand-1), 0.5);
    border-radius: 50%;
    animation: spin 1.5s linear infinite reverse;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .loading-text {
    font-size: 1rem;
    color: var(--color-text-alt);
    font-weight: 500;
    font-style: italic;
  }

  .progress-bar-wrapper {
    width: min(400px, 80vw);
    height: 6px;
    background: rgba(var(--rgb-brand-1), 0.12);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: var(--color-brand-1);
    border-radius: 999px;
    transition: width 0.6s var(--ease-out-expo);
  }

  .progress-label {
    font-size: 0.85rem;
    color: var(--color-text-alt);
    font-style: italic;
  }

  /* ── Error ── */
  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 4rem 1rem;
  }

  .error-icon {
    font-size: 3rem;
  }

  .error-text {
    font-size: 1.1rem;
    color: var(--color-text);
    text-align: center;
  }

  .back-btn {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.6rem 1.6rem;
    background: var(--color-brand-1);
    color: var(--color-white);
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s var(--ease-out-expo);
  }

  .back-btn:hover {
    filter: brightness(1.1);
    transform: scale(1.04);
  }

  /* ── Results Container ── */
  .results-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Thought Process (Deep Thinking) ── */
  .thought-container {
    background: var(--color-surface);
    border: 1px solid rgba(var(--rgb-brand-1), 0.15);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .thought-header {
    width: 100%;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(var(--rgb-brand-1), 0.03);
    border: none;
    border-bottom: 1px solid rgba(var(--rgb-brand-1), 0.1);
    cursor: pointer;
    text-align: left;
    transition: background 0.2s;
  }

  .thought-header:hover {
    background: rgba(var(--rgb-brand-1), 0.06);
  }

  .thought-icon {
    font-size: 1.2rem;
    filter: drop-shadow(0 0 8px rgba(var(--rgb-brand-1), 0.4));
  }

  .thought-title {
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-brand-1);
    flex-grow: 1;
  }

  .thought-arrow {
    width: 10px;
    height: 10px;
    border-right: 2px solid var(--color-brand-1);
    border-bottom: 2px solid var(--color-brand-1);
    transform: rotate(-135deg);
    transition: transform 0.3s;
    margin-right: 0.5rem;
  }

  .thought-container.is-collapsed .thought-arrow {
    transform: rotate(45deg);
  }

  .thought-container.is-collapsed .thought-content {
    display: none;
  }

  .thought-content {
    padding: 1.2rem;
  }

  .thought-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .thought-section {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    min-width: 0; /* Crucial for preventing grid item overflow */
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-alt);
    opacity: 0.8;
  }

  .section-a {
    grid-column: 1 / 2;
    border-right: 1px solid rgba(var(--rgb-brand-1), 0.12);
    padding-right: 1.2rem;
  }

  .section-b {
    grid-column: 2 / 3;
    padding-left: 0.2rem;
    position: relative;
    max-height: 0; /* Important: allow grid to define row height, then fill it */
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }

  .scroll-wrapper-b {
    flex: 1;
    overflow-y: auto;
    padding-right: 0.8rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(var(--rgb-brand-1), 0.2) transparent;
  }

  .scroll-wrapper-b::-webkit-scrollbar {
    width: 6px;
  }

  .scroll-wrapper-b::-webkit-scrollbar-track {
    background: transparent;
  }

  .scroll-wrapper-b::-webkit-scrollbar-thumb {
    background: rgba(var(--rgb-brand-1), 0.2);
    border-radius: 10px;
  }

  .section-c {
    grid-column: 1 / 3;
    border-top: 1px solid rgba(var(--rgb-brand-1), 0.15);
    padding-top: 1.2rem;
    margin-top: 0.5rem;
    min-height: auto;
  }

  @media (max-width: 640px) {
    .check-page {
      padding-top: 60px;
      padding-left: 0 !important;
      padding-right: 0 !important;
      overflow-x: hidden;
    }
    .u-container {
      padding: 0 !important;
      margin: 0 !important;
      max-width: 100% !important;
      width: 100% !important;
    }
    .results-container {
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      gap: 1rem;
    }
    .thought-container {
      border-radius: 0;
      border-left: none;
      border-right: none;
      width: 100vw !important;
    }
    .thought-content {
      padding: 0.75rem;
      width: 100%;
      box-sizing: border-box;
    }
    .thought-grid {
      grid-template-columns: 1fr;
      width: 100%;
    }
    .section-a, .section-b, .section-c {
      grid-column: 1 / 2;
      border-right: none;
      padding-right: 0;
      padding-left: 0;
      width: 100%;
      min-width: 0;
    }
    .section-b {
      border-top: 1px solid rgba(var(--rgb-brand-1), 0.12);
      padding-top: 1.2rem;
      max-height: none;
      min-height: auto;
    }
    .scroll-wrapper-b {
      overflow-y: visible;
      padding-right: 0;
    }
    .section-c {
      max-height: none;
    }
    .col-title {
      margin-left: 0.8rem;
      margin-right: 0.8rem;
    }
    .summary-box {
      margin-left: 0.5rem;
      margin-right: 0.5rem;
      padding: 1.2rem;
    }
  }

  /* ── Chart Styles ── */
  .mini-table {
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(var(--rgb-brand-1), 0.1);
    padding-bottom: 1rem;
  }

  .charts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .chart-item {
    background: var(--color-bg-alt);
    border-radius: 12px;
    padding: 1rem;
    border: 1px solid rgba(var(--rgb-brand-1), 0.08);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    display: none; /* Changed from flex */
    flex-direction: column;
    gap: 0.8rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .chart-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .chart-item:hover {
    background: rgba(var(--rgb-brand-1), 0.05);
    border-color: rgba(var(--rgb-brand-1), 0.2);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(var(--rgb-brand-1), 0.08);
  }

  .chart-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-alt);
    text-align: center;
  }

  .chart-canvas-wrapper {
    position: relative;
    height: 280px;
    width: 100%;
  }

  /* ── Data & Text Styles ── */
  .table-wrapper {
    width: 100%;
    margin-top: 0.5rem;
  }

  .financial-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    border-top: 2px solid var(--color-brand-1);
  }

  .financial-table tr {
    transition: background 0.2s;
  }

  .financial-table tr:hover {
    background: rgba(var(--rgb-brand-1), 0.04);
  }

  .financial-table th {
    padding: 0.8rem 0.5rem;
    text-align: left;
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--color-text-alt);
    border-bottom: 2px solid rgba(var(--rgb-brand-1), 0.15);
    background: rgba(var(--rgb-brand-1), 0.02);
  }

  .financial-table th:last-child {
    text-align: right;
  }

  .financial-table td {
    padding: 0.75rem 0.5rem;
    border-bottom: 1px solid rgba(var(--rgb-brand-1), 0.08);
  }

  .data-key {
    color: var(--color-text-alt);
    font-weight: 500;
    font-size: 0.85rem;
    width: 40%;
  }

  .data-value {
    font-family: var(--font-mono, 'Inter', monospace);
    font-weight: 700;
    color: var(--color-brand-1);
    font-size: 1.15rem; /* Larger than B/C */
    text-align: right;
    letter-spacing: -0.02em;
  }

  .numeric {
    font-variant-numeric: tabular-nums;
  }

  .text-output {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text);
    min-height: 1.5em;
    opacity: 0.9;
  }

  /* ── Rich Text Analysis Cards (Section B) ── */
  .analysis-card {
    background: rgba(var(--rgb-brand-1), 0.03);
    border-left: 4px solid var(--color-brand-1);
    border-radius: 8px;
    padding: 1.2rem;
    margin-bottom: 1.5rem;
    animation: fadeIn 0.5s ease-out;
  }

  .analysis-card h3 {
    margin: 0 0 0.8rem 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-brand-1);
  }

  .analysis-card .conclusion {
    font-weight: 600;
    margin-bottom: 0.8rem;
    color: var(--color-text);
  }

  .analysis-card .details-list {
    margin: 0.5rem 0;
    padding-left: 1.2rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .analysis-card .details-list li {
    font-size: 0.9rem;
    position: relative;
    padding-left: 1rem;
    color: var(--color-text-alt);
  }

  .analysis-card .details-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--color-brand-1);
    font-weight: bold;
  }

  .analysis-card .label {
    font-weight: 700;
    color: var(--color-text-alt);
    font-size: 0.8rem;
    text-transform: uppercase;
    margin-right: 0.5rem;
  }

  .analysis-card .implication {
    margin-top: 1rem;
    padding-top: 0.8rem;
    border-top: 1px dashed rgba(var(--rgb-brand-1), 0.15);
    font-style: italic;
  }

  /* ── Audit Items (Section C) ── */
  .audit-item {
    padding: 1rem;
    border-radius: 10px;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    animation: slideIn 0.4s ease-out;
  }

  .audit-item.challenge {
    background: rgba(239, 68, 68, 0.05);
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .audit-item.resolved {
    background: rgba(34, 197, 94, 0.05);
    border: 1px solid rgba(34, 197, 94, 0.2);
  }

  .audit-icon-text {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .audit-item.challenge .audit-icon-text { color: #ef4444; }
  .audit-item.resolved .audit-icon-text { color: #22c55e; }

  .audit-content {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .audit-meta {
    font-size: 0.75rem;
    color: var(--color-text-alt);
    margin-top: 0.3rem;
  }

  /* ── Progress Updates ── */
  .progress-update {
    font-size: 0.85rem;
    color: var(--color-text-alt);
    font-style: italic;
    margin-bottom: 0.8rem;
    opacity: 0.7;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(-5px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .text-output::after {
    content: '';
    display: inline-block;
    width: 2px;
    height: 1em;
    background: var(--color-brand-1);
    margin-left: 2px;
    vertical-align: middle;
    animation: blink 0.8s infinite;
  }

  .text-output.is-done::after {
    display: none;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  /* ── Summary Container ── */
  .summary-container {
    padding-bottom: 2rem;
  }

  .col-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-alt);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.8rem;
  }

  .summary-box {
    background: var(--color-surface);
    border: 2px solid var(--color-brand-1);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    box-shadow: 0 4px 24px rgba(var(--rgb-brand-1), 0.12);
  }

  .final-result-output {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px dashed rgba(var(--rgb-brand-1), 0.2);
    font-weight: 600;
    color: var(--color-brand-1);
    font-size: 1.1rem;
  }

  .is-placeholder {
    color: var(--color-text-alt);
    font-style: italic;
    opacity: 0.6;
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.7; }
  }

  /* ── Preview CTA ── */
  .preview-cta-container {
    display: flex;
    justify-content: center;
    padding: 2rem 0 4rem;
    animation: fadeIn 0.8s ease-out;
  }

  .cta-button {
    display: inline-block;
    padding: 1.1rem 2.8rem;
    background: linear-gradient(135deg, var(--color-brand-1), #9333ea);
    color: white !important;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1.15rem;
    text-decoration: none;
    box-shadow: 0 10px 20px -5px rgba(var(--rgb-brand-1), 0.4);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .cta-button:hover {
    transform: translateY(-4px) scale(1.03);
    box-shadow: 0 15px 30px -5px rgba(var(--rgb-brand-1), 0.5);
    filter: brightness(1.1);
  }

  .cta-button:active {
    transform: translateY(-1px) scale(0.98);
  }

  @media (max-width: 640px) {
    .cta-button {
      padding: 1.25rem 2rem;
      width: 100%;
      text-align: center;
      font-size: 1.1rem;
    }
  }

  /* ── Utility ── */
  .hidden {
    display: none !important;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  // ── i18n strings passed from Astro ──
  const metaEl = document.querySelector('meta[name="check-i18n"]');
  const i18n = metaEl ? JSON.parse(metaEl.getAttribute('content') || '{}') : {};

  // ── Helper: get lang from URL ──
  const isEn = window.location.pathname.startsWith('/en');
  const lang = isEn ? 'en' : 'zh-CN';

  // ── Grab URL params ──
  const params = new URLSearchParams(window.location.search);
  const code = params.get('code');
  const year = params.get('year');
  const period = params.get('period');
  const preview = params.get('preview');

  // DOM refs
  const loadingEl = document.getElementById('loading-container')!;
  const errorEl = document.getElementById('error-container')!;
  const resultsEl = document.getElementById('results-container')!;
  const pageTitleEl = document.getElementById('page-title')!;
  const loadingTextEl = document.getElementById('loading-text')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressLabel = document.getElementById('progress-label')!;
  const errorTextEl = document.getElementById('error-text')!;

  const thoughtContainer = document.getElementById('thought-container')!;
  const thoughtToggle = document.getElementById('thought-toggle')!;
  const textB = document.getElementById('text-b') as HTMLElement;
  const textC = document.getElementById('text-c') as HTMLElement;
  const summaryText = document.getElementById('summary-text')!;
  const finalResultText = document.getElementById('final-result-text')!;

  // ── Placeholder Manager for B & C ──
  class PlaceholderManager {
    private interval: any = null;
    private messages: string[] = [];
    private currentIndex = 0;

    constructor(private element: HTMLElement, messages: string[]) {
      this.messages = messages;
    }

    start() {
      if (this.messages.length === 0) return;
      this.element.classList.add('is-placeholder');
      this.element.textContent = this.messages[0];
      this.interval = setInterval(() => {
        this.currentIndex = (this.currentIndex + 1) % this.messages.length;
        this.element.textContent = this.messages[this.currentIndex];
      }, 3000);
    }

    stop() {
      if (this.interval) {
        clearInterval(this.interval);
        this.interval = null;
        this.element.textContent = '';
        this.element.classList.remove('is-placeholder');
      }
    }

    isActive() {
      return this.interval !== null;
    }
  }

  const bcMessages = lang === 'zh-CN' ? [
    '正在多维核对财报钩稽关系...',
    '正在执行收入截止性测试...',
    '正在分析营运资金周转效率...',
    '正在评估资产减值准备计提...',
    '正在核算加权平均资本成本...',
    '正在比对历史趋势异常波动...',
    '正在检验研发投入资本化比例...',
    '正在审计关联方交易公允性...',
    '正在验证存货周转率合理性...',
    '正在解析财报附注深度内涵...',
    '正在扫描潜在表外融资风险...'
  ] : [
    'Cross-checking financial statement integrity...',
    'Performing revenue cutoff tests...',
    'Analyzing working capital efficiency...',
    'Evaluating asset impairment provisions...',
    'Calculating Weighted Average Cost of Capital...',
    'Inspecting historical trend anomalies...',
    'Verifying R&D capitalization ratios...',
    'Auditing related-party transaction fairness...',
    'Validating inventory turnover logic...',
    'Parsing deep insights from footnotes...',
    'Scanning for off-balance sheet risks...'
  ];

  const placeholderB = new PlaceholderManager(textB, bcMessages);
  const placeholderC = new PlaceholderManager(textC, bcMessages);

  // Initialize Summary Placeholder
  summaryText.textContent = lang === 'zh-CN' ? '正在等待分析完成...' : 'Waiting for analysis to complete...';
  summaryText.classList.add('is-placeholder');

  // Toggle thought process
  thoughtToggle.addEventListener('click', () => {
    thoughtContainer.classList.toggle('is-collapsed');
    thoughtToggle.setAttribute('aria-expanded', String(!thoughtContainer.classList.contains('is-collapsed')));
  });

  // ── Chart Manager ──
  class ChartManager {
    private charts: Record<string, any> = {};

    private getOptions(title: string, suffix: string = '') {
      const isDark = document.documentElement.classList.contains('dark');
      const textColor = isDark ? '#94a3b8' : '#64748b';
      const gridColor = isDark ? 'rgba(148, 163, 184, 0.1)' : 'rgba(100, 116, 139, 0.1)';
      const brandColor = 'rgba(124, 58, 237, 1)'; // var(--color-brand-1) approximation

      return {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            mode: 'index',
            intersect: false,
            filter: (item: any) => item.datasetIndex === 0,
            callbacks: {
              label: (context: any) => {
                let label = context.dataset.label || '';
                if (label) label += ': ';
                if (context.parsed.y !== null) {
                  label += context.parsed.y.toLocaleString() + suffix;
                }
                return label;
              }
            }
          }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: textColor, font: { size: 10 } }
          },
          y: {
            grid: { color: gridColor },
            ticks: { 
              color: textColor, 
              font: { size: 10 },
              callback: (value: any) => {
                if (suffix === '%') return value + '%';
                if (value >= 100000000) return (value / 100000000).toFixed(1) + '亿';
                if (value >= 10000) return (value / 10000).toFixed(0) + '万';
                return value;
              }
            }
          }
        }
      };
    }

    render(id: string, data: any[], label: string, suffix: string = '') {
      const ctx = document.getElementById(id) as HTMLCanvasElement;
      if (!ctx) return;

      // Reveal the parent container
      const container = ctx.closest('.chart-item') as HTMLElement;
      if (container) {
        container.style.display = 'flex';
        // Minor delay to trigger CSS transition
        setTimeout(() => container.classList.add('is-visible'), 10);
      }

      // Ensure the section itself is visible
      const sectionA = document.querySelector('.section-a');
      if (sectionA) sectionA.classList.remove('hidden');

      if (this.charts[id]) {
        this.charts[id].destroy();
      }

      // @ts-ignore (Chart.js via CDN)
      this.charts[id] = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: data.map(d => d.period),
          datasets: [
            {
              label: label,
              data: data.map(d => d.value),
              backgroundColor: 'rgba(124, 58, 237, 0.2)',
              borderColor: 'rgba(124, 58, 237, 0.8)',
              borderWidth: 1,
              order: 2,
              borderRadius: 4,
            },
            {
              label: lang === 'zh-CN' ? '趋势' : 'Trend',
              data: data.map(d => d.value),
              type: 'line',
              borderColor: 'rgba(124, 58, 237, 1)',
              borderWidth: 2,
              pointRadius: 3,
              pointBackgroundColor: 'rgba(124, 58, 237, 1)',
              tension: 0.4,
              order: 1
            }
          ]
        },
        options: this.getOptions(label, suffix)
      });
    }
  }

  const chartManager = new ChartManager();

  /**
   * Simple Typewriter effect for streaming feel
   */
  class Typewriter {
    private queue: { text?: string; html?: string }[] = [];
    private isRunning = false;
    private speed = 15; // ms per char
    private scrollParent: HTMLElement | null = null;

    constructor(private element: HTMLElement) {
      this.scrollParent = element.closest('.scroll-wrapper-b') || element.closest('.text-output');
    }

    write(text: string) {
      if (!text) return;
      this.queue.push({ text });
      if (!this.isRunning) this.run();
    }

    writeHTML(html: string) {
      if (!html) return;
      this.queue.push({ html });
      if (!this.isRunning) this.run();
    }

    private async run() {
      this.isRunning = true;
      this.element.classList.remove('is-done');
      while (this.queue.length > 0) {
        const item = this.queue.shift();
        if (!item) continue;

        if (item.html) {
          this.element.insertAdjacentHTML('beforeend', item.html);
          this.autoScroll();
          await new Promise(r => setTimeout(r, 200));
        } else if (item.text) {
          const chars = item.text.split('');
          for (const char of chars) {
            this.element.insertAdjacentText('beforeend', char);
            if (char === '\n') this.autoScroll();
            await new Promise(r => setTimeout(r, this.speed));
          }
        }
        this.autoScroll();
      }
      this.isRunning = false;
      this.element.classList.add('is-done');
    }

    private autoScroll() {
      if (this.scrollParent) {
        this.scrollParent.scrollTo({
          top: this.scrollParent.scrollHeight,
          behavior: 'smooth'
        });
      }
    }

    done() {
      this.element.classList.add('is-done');
    }
  }

  const writers = {
    b: new Typewriter(textB),
    c: new Typewriter(textC),
    summary: new Typewriter(summaryText),
  };

  async function renderCharts(history: any[]) {
    if (!history || history.length === 0) return;
    
    // Sort to show chronological order
    const sorted = [...history].sort((a, b) => {
        return a.reporting_period.localeCompare(b.reporting_period);
    });

    const revenueData = sorted.map(h => ({ period: h.reporting_period, value: h.revenue }));
    const profitData = sorted.map(h => ({ period: h.reporting_period, value: h.net_profit }));
    const marginData = sorted.map(h => ({ period: h.reporting_period, value: h.gross_margin }));
    const debtData = sorted.map(h => ({ period: h.reporting_period, value: h.debt_to_asset }));

    const chartConfigs = [
      { id: 'chart-revenue', data: revenueData, label: formatKey('revenue'), suffix: '' },
      { id: 'chart-profit', data: profitData, label: formatKey('net_profit'), suffix: '' },
      { id: 'chart-margin', data: marginData, label: formatKey('gross_margin'), suffix: '%' },
      { id: 'chart-debt', data: debtData, label: formatKey('debt_to_asset'), suffix: '%' },
    ];

    for (const config of chartConfigs) {
      if (config.data.some(d => d.value !== null && d.value !== undefined)) {
        chartManager.render(config.id, config.data, config.label, config.suffix);
        await new Promise(r => setTimeout(r, 600)); // Sequential delay for streaming feel
      }
    }
  }

  function formatSymbol(codeParam: string | null): string {
    if (!codeParam) return '';
    if (codeParam.includes('.')) return codeParam;
    const match = codeParam.match(/^([a-z]+)(\d+)$/i);
    if (match) {
      return `${match[2]}.${match[1].toUpperCase()}`;
    }
    return codeParam;
  }

  function formatKey(key: string): string {
    const map: Record<string, string> = {
      'name': lang === 'zh-CN' ? '公司名称' : 'Company Name',
      'ticker': lang === 'zh-CN' ? '股票代码' : 'Ticker',
      'reporting_period': lang === 'zh-CN' ? '报告期' : 'Period',
      'release_date': lang === 'zh-CN' ? '发布日期' : 'Release Date',
      'revenue': lang === 'zh-CN' ? '营业收入' : 'Revenue',
      'net_profit': lang === 'zh-CN' ? '净利润' : 'Net Profit',
      'gross_margin': lang === 'zh-CN' ? '毛利率' : 'Gross Margin',
      'roe': lang === 'zh-CN' ? 'ROE' : 'ROE',
      'total_assets': lang === 'zh-CN' ? '总资产' : 'Total Assets',
      'total_liabilities': lang === 'zh-CN' ? '总负债' : 'Total Liabs',
      'debt_to_asset': lang === 'zh-CN' ? '资产负债率' : 'Debt Ratio',
    };
    return map[key] || key;
  }

  function showError(msg?: string) {
    loadingEl.classList.add('hidden');
    errorEl.classList.remove('hidden');
    if (msg && errorTextEl) errorTextEl.textContent = msg;
  }

  async function typeText(el: HTMLElement, text: string, speed = 20) {
    if (!el || !text) return;
    const chars = text.split('');
    for (const char of chars) {
      el.textContent += char;
      if (char === '\n' || char === '。' || char === '.') {
        const scrollParent = el.closest('.scroll-wrapper-b') || el.closest('.text-output');
        if (scrollParent) scrollParent.scrollTo({ top: scrollParent.scrollHeight, behavior: 'smooth' });
      }
      await new Promise(r => setTimeout(r, speed));
    }
    // Final scroll
    const scrollParent = el.closest('.scroll-wrapper-b') || el.closest('.text-output');
    if (scrollParent) scrollParent.scrollTo({ top: scrollParent.scrollHeight, behavior: 'smooth' });
  }

  function setProgress(pct: number, label?: string) {
    progressBar.style.width = pct + '%';
    progressLabel.textContent = pct + '%';
    if (label) loadingTextEl.textContent = label;
  }

  /**
   * Process a single event from the stream
   */
  async function processEvent(item: any) {
    if (!item) return;
    console.log('[Stream Event]', item);
    const { producer, event, data } = item;
    const value = item.value || data; // Handle alternate field names

    if (event === 'a_data') {
      const { label, data: chartData, type, suffix } = value;
      if (label && chartData) {
        const idMap: Record<string, string> = {
          'Revenue': 'chart-revenue',
          '营业收入': 'chart-revenue',
          'Net Profit': 'chart-profit',
          '净利润': 'chart-profit',
          'Gross Margin': 'chart-margin',
          '毛利率': 'chart-margin',
          'Debt Ratio': 'chart-debt',
          '资产负债率': 'chart-debt'
        };
        const id = idMap[label] || `chart-${label.toLowerCase()}`;
        chartManager.render(id, chartData.map((d:any) => typeof d === 'object' ? d : {period: '', value: d}), label, suffix || '');
        await new Promise(r => setTimeout(r, 400));
      }
      return;
    }

    // Normalize producer name (A, B, C or normalizer, analyzer, auditor)
    const p = (producer || '').toUpperCase();

    if ((p === 'A' || p === 'NORMALIZER') && (event === 'a_normalized' || event === 'data')) {
      const d = data || item.data; // Handle if data is directly in item or nested
      if (!d) return;
      
      const { company, report, income_statement, balance_sheet, key_ratios, history_12q } = d;
      
      if (history_12q) {
        renderCharts(history_12q);
      }

      if (company) {
        // Update Page Title dynamically
        const companyName = company.name || '';
        let periodText = company.reporting_period || '';
        // Localize 'FY' to '年度' for Chinese
        if (lang === 'zh-CN' && periodText.toLowerCase().includes('fy')) {
          periodText = periodText.replace(/fy/i, '年度');
        }

        if (companyName) {
          pageTitleEl.textContent = `${companyName} (${periodText}) 财报分析`;
          document.title = `${companyName} (${periodText}) 财报分析 - Ezer Audit`;
        }
      }
    }

    if ((p === 'B' || p === 'ANALYZER')) {
      if (placeholderB.isActive()) placeholderB.stop();
      const d = data || item.data;
      if (!d) return;

      if (event === 'b_progress') {
        writers.b.writeHTML(`<div class="progress-update"><i>› 正在 ${d.task || d.step || '执行分析'}...</i></div>`);
        return;
      }

      if (event === 'b_card' || event === 'analysis') {
        const card = document.createElement('div');
        card.className = 'analysis-card';
        
        if (d.title) {
          const h3 = document.createElement('h3');
          h3.textContent = d.title;
          card.appendChild(h3);
        }
        
        const conclusion = document.createElement('p');
        conclusion.className = 'conclusion';
        card.appendChild(conclusion);
        
        writers.b.element.appendChild(card);
        if (d.conclusion) await typeText(conclusion, d.conclusion, 15);

        const detailsList = document.createElement('ul');
        detailsList.className = 'details-list';
        card.appendChild(detailsList);

        const fields = [
          { key: 'evidence', label: lang === 'zh-CN' ? '依据' : 'Evidence' },
          { key: 'cross_checks', label: lang === 'zh-CN' ? '交叉验证' : 'Cross-checks' },
          { key: 'counterpoints', label: lang === 'zh-CN' ? '反向观点' : 'Counterpoints' }
        ];

        for (const field of fields) {
          const val = d[field.key];
          if (val && val.length) {
            const li = document.createElement('li');
            li.innerHTML = `<span class="label">${field.label}:</span> `;
            const textSpan = document.createElement('span');
            li.appendChild(textSpan);
            detailsList.appendChild(li);
            const text = Array.isArray(val) ? val.join(', ') : val;
            await typeText(textSpan, text, 10);
          }
        }

        if (d.investor_implication) {
          const implication = document.createElement('p');
          implication.className = 'implication';
          implication.innerHTML = `<span class="label">${lang === 'zh-CN' ? '投资启示' : 'Investor Implication'}:</span> `;
          const textSpan = document.createElement('span');
          implication.appendChild(textSpan);
          card.appendChild(implication);
          await typeText(textSpan, d.investor_implication, 15);
        }
      }
    }

    if ((p === 'C' || p === 'AUDITOR')) {
      if (placeholderC.isActive()) placeholderC.stop();
      const d = data || item.data;
      if (!d) return;

      if (event === 'c_progress') {
        writers.c.writeHTML(`<div class="progress-update"><i>› 正在 ${d.task || d.step || '执行审计'}...</i></div>`);
        return;
      }

      if (event === 'c_challenge') {
        const div = document.createElement('div');
        div.className = 'audit-item challenge';
        div.innerHTML = `<div class="audit-icon-text">⚠️ ${lang === 'zh-CN' ? '审计挑战' : 'Audit Challenge'} (${d.severity || 'MEDIUM'})</div>`;
        const content = document.createElement('div');
        content.className = 'audit-content';
        div.appendChild(content);
        if (d.target_card_id) {
          const meta = document.createElement('div');
          meta.className = 'audit-meta';
          meta.textContent = (lang === 'zh-CN' ? '针对: ' : 'Target: ') + d.target_card_id;
          div.appendChild(meta);
        }
        writers.c.element.appendChild(div);
        if (d.issue) await typeText(content, d.issue, 15);
      }

      if (event === 'c_resolved' || event === 'audit') {
        const div = document.createElement('div');
        div.className = 'audit-item resolved';
        div.innerHTML = `<div class="audit-icon-text">✅ ${lang === 'zh-CN' ? '审计通过' : 'Audit Passed'}</div>`;
        const content = document.createElement('div');
        content.className = 'audit-content';
        div.appendChild(content);
        if (d.target_card_id) {
          const meta = document.createElement('div');
          meta.className = 'audit-meta';
          meta.textContent = (lang === 'zh-CN' ? '解决项: ' : 'Resolved: ') + d.target_card_id;
          div.appendChild(meta);
        }
        writers.c.element.appendChild(div);
        const textToType = d.rationale || d.content || d.text || '';
        if (textToType) await typeText(content, textToType, 15);
      }
    }

    if (event === 'final_summary' || event === 'summary') {
      if (summaryText.classList.contains('is-placeholder')) {
        summaryText.textContent = '';
        summaryText.classList.remove('is-placeholder');
      }
      const d = data || item.data;
      if (d) {
        const text = d.summary || d.content || d.text || '';
        await typeText(summaryText, text, 15);
      }
    }

    if (event === 'final_result' || event === 'result') {
      const d = data || item.data;
      if (d) {
        finalResultText.classList.remove('hidden');
        const prefix = lang === 'zh-CN' ? '最终结果：' : 'Final Result: ';
        finalResultText.textContent = prefix + (d.final_status || d.status || d.result || '');
      }
    }

    if (event === 'error' || event === 'task_failed') {
      const d = data || item.data;
      const msg = d?.message || d?.error || 'Unknown error occurred';
      showError(msg);
      return;
    }
  }

  /**
   * Main logic to handle simulated stream
   */
  async function processStream(stream: any[]) {
    loadingEl.classList.add('hidden');
    resultsEl.classList.remove('hidden');

    // Start placeholders
    placeholderB.start();
    placeholderC.start();

    for (const item of stream) {
      processEvent(item);
      await new Promise(r => setTimeout(r, 200));
    }
  }

  // ── Main entry point ──
  async function main() {
    try {
      const apiParams = new URLSearchParams();
      if (code) apiParams.set('code', code);
      if (year) apiParams.set('year', year);
      if (period) apiParams.set('period', period);
      if (preview) apiParams.set('preview', preview);
      apiParams.set('lang', lang);

      console.log('--- Initiating Audit via Local API ---');
      setProgress(10, lang === 'zh-CN' ? '正在开启智能查验...' : 'Initiating smart audit...');
      
      const response = await fetch(`/api/check?${apiParams.toString()}`);
      if (!response.ok) {
        const errData = await response.json().catch(() => ({}));
        throw new Error(errData.error || `Server error: ${response.status}`);
      }

      loadingEl.classList.add('hidden');
      resultsEl.classList.remove('hidden');

      // Start placeholders
      placeholderB.start();
      placeholderC.start();

      if (!response.body) {
        throw new Error('Response body is empty');
      }

      console.log('Streaming started from local API...');
      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        
        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed) continue;
          try {
            const item = JSON.parse(trimmed);
            await processEvent(item);
          } catch (e) { 
            console.error('Failed to parse stream line:', trimmed, e); 
          }
        }
      }

      if (buffer.trim()) {
        try {
          const evt = JSON.parse(buffer.trim());
          processEvent(evt);
        } catch (e) {}
      }

    } catch (err: any) {
      showError(err.message);
    }
  }

  // ── Scroll Behavior for Area B/C (Desktop) ──
  const setupAreaScroll = () => {
    const wrappers = document.querySelectorAll('.scroll-wrapper-b');
    wrappers.forEach(wrapper => {
      wrapper.addEventListener('wheel', (e: any) => {
        if (window.innerWidth > 640) {
          const { scrollTop, scrollHeight, clientHeight } = wrapper;
          const isAtTop = scrollTop === 0;
          const isAtBottom = Math.abs(scrollTop + clientHeight - scrollHeight) < 2;

          const scrollingDown = e.deltaY > 0;
          const scrollingUp = e.deltaY < 0;

          // If we are NOT at the boundary in the direction of scrolling, 
          // stop propagation to prevent Lenis from scrolling the page.
          if ((scrollingDown && !isAtBottom) || (scrollingUp && !isAtTop)) {
            e.stopPropagation();
          }
        }
      }, { passive: true });
    });
  };
  setupAreaScroll();

  main().then(() => {
    // Show CTA if in preview mode
    if (preview === 'true') {
      const cta = document.getElementById('preview-cta-container');
      if (cta) cta.classList.remove('hidden');
    }
  });
</script>
