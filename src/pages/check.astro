---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { ui } from "../i18n/ui";
import QuotaBanner from "../components/QuotaBanner.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translations = ui[lang];

// Check parameters
const code = Astro.url.searchParams.get('code');
const year = Astro.url.searchParams.get('year');
const period = Astro.url.searchParams.get('period');
const preview = Astro.url.searchParams.get('preview');

// 1. No parameters -> Redirect to search
if (!code && !year && !period && !preview) {
  return Astro.redirect(lang === 'zh' ? '/search/' : '/en/search/');
}

// 2. Auth check if not preview
if (preview !== 'true') {
  const cookies = Astro.request.headers.get('cookie') || '';
  const hasSession = cookies.includes('sb-msufgvqofnihylcnxyac-auth-token');
  
  if (!hasSession) {
    const loginUrl = `https://account.ezer.cc/${lang === 'en' ? 'en/' : ''}login/?redirect=${encodeURIComponent(Astro.url.href)}`;
    return Astro.redirect(loginUrl);
  }
}
---

<!-- Injected i18n for client-side script -->
<meta name="check-i18n" content={JSON.stringify(translations)} />

<Layout 
  title={t("check.title")}
  description="深度红蓝对抗财报分析报告。分析公司财务指标、潜在风险点及投资建议，提供可视化数据与完整证据链。"
  keywords="财报深度分析, 审计报告生成, 风险建议, 财务表现可视化"
>
  <div class="check-page">
    <div class="u-container">
      <!-- Page Header -->
      <div class="check-header">
        <h1 class="check-title" id="page-title">{t("check.title")}</h1>
      </div>

      <!-- Loading State -->
      <div class="loading-container" id="loading-container">
        <div class="financial-quantum-loader">
          <!-- Background Grid & Glow -->
          <div class="loader-backdrop"></div>
          <div class="scanning-beam"></div>
          
          <div class="loader-main">
            <!-- Central Dynamic Icon (Rotates through states) -->
            <div class="pivot-icon">
              <div class="icon-state s-shield active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div class="icon-state s-chart">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>
              </div>
              <div class="icon-state s-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              </div>
            </div>
            
            <!-- Candlestick Animation -->
            <div class="finance-viz">
              <div class="candle c1"></div>
              <div class="candle c2"></div>
              <div class="candle c3"></div>
              <div class="candle c4"></div>
              <div class="candle c5"></div>
            </div>

            <!-- Ticker Band -->
            <div class="ticker-tape">
              <div class="ticker-track">
                <span>REVENUE_VAL: OK</span><span>NET_PROFIT: STABLE</span><span>DEBT_RATIO: 42%</span><span>AUDIT_PROC_INIT</span><span>CROSS_CHECKED</span><span>CASH_FLOW_PULSE</span>
              </div>
            </div>

            <!-- Data Flux Particles -->
            <div class="data-flux">
              <span class="flux-item">RISK:LOW</span>
              <span class="flux-item">AUDIT:PASS</span>
              <span class="flux-item">DATA:99.9%</span>
              <span class="flux-item">ROI:12%</span>
            </div>
          </div>
          
          <!-- Outer Orbits -->
          <div class="orbit-path op-1"></div>
          <div class="orbit-path op-2"></div>
        </div>

        <div class="loading-info">
          <p class="loading-text" id="loading-text">{t("check.loading")}</p>
          <div class="progress-bar-wrapper">
            <div class="progress-bar" id="progress-bar"></div>
            <div class="progress-glow"></div>
          </div>
          <p class="progress-label" id="progress-label">0%</p>
        </div>
      </div>

      <!-- Error State -->
      <div class="error-container hidden" id="error-container">
        <div class="error-icon">⚠️</div>
        <p class="error-text" id="error-text">{t("check.error")}</p>
        <a id="back-link" href={lang === "zh" ? "/search/" : "/en/search/"} class="back-btn">
          ← {lang === "zh" ? "返回搜索" : "Back to Search"}
        </a>
        <a id="upgrade-link" href={lang === "zh" ? "/premium/?from=exceed" : "/en/premium/?from=exceed"} class="back-btn hidden">
          {t("quota.upgrade_now")}
        </a>
      </div>

      <!-- Results -->
      <div class="results-container hidden" id="results-container">
        <!-- Thought Process (A, B, C) -->
        <div class="thought-container" id="thought-container">
          <button class="thought-header" id="thought-toggle" aria-expanded="true">
            <span class="thought-icon">📊</span>
            <span class="thought-title">{t("check.thought")}</span>
            <span class="thought-arrow"></span>
          </button>
          
          <div class="thought-content" id="thought-content">
            <div class="thought-grid">
              <!-- A: Structured Data -->
              <div class="thought-section section-a hidden">
                <div class="section-label">数据归一化 (A)</div>
                <div class="charts-grid" id="charts-a">
                  <div class="chart-item">
                    <div class="chart-label">营业收入</div>
                    <div class="chart-canvas-wrapper">
                      <canvas id="chart-revenue"></canvas>
                    </div>
                  </div>
                  <div class="chart-item">
                    <div class="chart-label">净利润</div>
                    <div class="chart-canvas-wrapper">
                      <canvas id="chart-profit"></canvas>
                    </div>
                  </div>
                  <div class="chart-item">
                    <div class="chart-label">毛利率</div>
                    <div class="chart-canvas-wrapper">
                      <canvas id="chart-margin"></canvas>
                    </div>
                  </div>
                  <div class="chart-item">
                    <div class="chart-label">资产负债率</div>
                    <div class="chart-canvas-wrapper">
                      <canvas id="chart-debt"></canvas>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- B: Analysis Text -->
              <div class="thought-section section-b">
                <div class="section-label">深度分析 (B)</div>
                <div class="scroll-wrapper-b">
                  <div class="text-output" id="text-b"></div>
                </div>
              </div>
              
              <!-- C: Auditor Text -->
              <div class="thought-section section-c">
                <div class="section-label">风险审计 (C)</div>
                <div class="scroll-wrapper-b">
                  <div class="text-output" id="text-c"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Summary Section -->
        <div class="summary-container" id="summary-section-container">
          <h2 class="col-title">{t("check.headline")}</h2>
          <div class="summary-box">
            <div id="summary-text" class="text-output"></div>
            <div id="final-result-text" class="final-result-output hidden"></div>
          </div>
        </div>
        
      </div>
    </div>
    <QuotaBanner />
  </div>
</Layout>

<style>
  .check-page {
    min-height: 100vh;
    padding: 10vh 1rem 4rem;
    background: var(--color-bg);
  }

  /* ── Header ── */
  .check-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .check-title {
    font-family: var(--font-roboto-slab);
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    color: var(--color-text);
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  /* ── Loading ── */
  .loading-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    padding: 0 1rem 4rem;
    min-height: 55vh;
  }

  .financial-quantum-loader {
    position: relative;
    width: 280px;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 24px;
    background: rgba(var(--rgb-brand-1), 0.02);
    border: 1px solid rgba(var(--rgb-brand-1), 0.1);
    box-shadow: inset 0 0 40px rgba(var(--rgb-brand-1), 0.05);
  }

  .loader-backdrop {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(var(--rgb-brand-1), 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(var(--rgb-brand-1), 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.3;
  }

  .scanning-beam {
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 40%;
    background: linear-gradient(to bottom, transparent, rgba(var(--rgb-brand-1), 0.2), transparent);
    animation: beam-scan 3s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes beam-scan {
    0% { top: -40%; }
    50% { top: 100%; }
    100% { top: -40%; }
  }

  .loader-main {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .pivot-icon {
    width: 60px;
    height: 60px;
    color: var(--color-brand-1);
    filter: drop-shadow(0 0 15px rgba(var(--rgb-brand-1), 0.5));
    position: relative;
    margin-bottom: 20px;
  }

  .icon-state {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(0.8) rotate(-10deg);
    transition: all 0.5s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-state.active {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .icon-state svg {
    width: 100%;
    height: 100%;
    stroke: var(--color-brand-1);
  }

  /* Auto-rotation of icons handled by animation or script? 
     Let's use a CSS animation for simplicity if possible, or just a CSS stagger */
  .s-shield { animation: state-cycle 9s infinite 0s; }
  .s-chart { animation: state-cycle 9s infinite 3s; }
  .s-search { animation: state-cycle 9s infinite 6s; }

  @keyframes state-cycle {
    0%, 28% { opacity: 1; transform: scale(1) rotate(0deg); }
    33.33%, 95% { opacity: 0; transform: scale(0.8) rotate(10deg); }
    100% { opacity: 0; }
  }

  /* Candlesticks */
  .finance-viz {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 60px;
    margin-bottom: 20px;
  }

  .candle {
    width: 10px;
    border-radius: 2px;
    position: relative;
  }

  .candle::after {
    content: '';
    position: absolute;
    left: 50%;
    width: 2px;
    height: 120%;
    bottom: -10%;
    transform: translateX(-50%);
    background: inherit;
    opacity: 0.4;
  }

  .c1 { height: 30px; background: #10b981; animation: fluctu-green 2s infinite 0s; }
  .c2 { height: 45px; background: #ef4444; animation: fluctu-red 2.5s infinite 0.3s; }
  .c3 { height: 25px; background: #10b981; animation: fluctu-green 1.8s infinite 0.6s; }
  .c4 { height: 50px; background: #10b981; animation: fluctu-green 2.2s infinite 0.9s; }
  .c5 { height: 35px; background: #ef4444; animation: fluctu-red 2.1s infinite 1.2s; }

  @keyframes fluctu-green {
    0%, 100% { height: 20px; }
    50% { height: 40px; }
  }
  @keyframes fluctu-red {
    0%, 100% { height: 50px; }
    50% { height: 25px; }
  }

  /* Ticker Tape */
  .ticker-tape {
    width: 120%;
    background: rgba(0, 0, 0, 0.2);
    padding: 4px 0;
    transform: rotate(-5deg);
    border-top: 1px solid rgba(var(--rgb-brand-1), 0.2);
    border-bottom: 1px solid rgba(var(--rgb-brand-1), 0.2);
    overflow: hidden;
  }

  .ticker-track {
    display: flex;
    white-space: nowrap;
    gap: 30px;
    animation: ticker-slide 15s linear infinite;
  }

  .ticker-track span {
    font-size: 0.7rem;
    font-family: var(--font-mono, monospace);
    font-weight: 700;
    color: var(--color-text-alt);
  }

  @keyframes ticker-slide {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Data Flux */
  .data-flux {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .flux-item {
    position: absolute;
    font-size: 0.6rem;
    font-weight: 800;
    color: var(--color-brand-1);
    background: rgba(var(--rgb-brand-1), 0.1);
    padding: 2px 6px;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    font-family: var(--font-mono, monospace);
  }

  .flux-item:nth-child(1) { top: 15%; left: 10%; animation: float-data 4s infinite 0s; }
  .flux-item:nth-child(2) { top: 20%; right: 10%; animation: float-data 4s infinite 1s; }
  .flux-item:nth-child(3) { bottom: 25%; left: 15%; animation: float-data 4s infinite 2s; }
  .flux-item:nth-child(4) { bottom: 15%; right: 15%; animation: float-data 4s infinite 3s; }

  @keyframes float-data {
    0% { transform: translateY(10px); opacity: 0; }
    10% { opacity: 0.8; }
    90% { opacity: 0.8; }
    100% { transform: translateY(-30px); opacity: 0; }
  }

  /* Orbit Paths */
  .orbit-path {
    position: absolute;
    border: 1px dashed rgba(var(--rgb-brand-1), 0.15);
    border-radius: 50%;
  }

  .op-1 { width: 140%; height: 140%; animation: rotate 20s linear infinite; }
  .op-2 { width: 180%; height: 180%; animation: rotate 30s linear infinite reverse; }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .loading-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 440px;
  }

  .loading-text {
    font-size: 1.1rem;
    color: var(--color-text);
    font-weight: 600;
    letter-spacing: -0.01em;
    text-align: center;
  }

  .progress-bar-wrapper {
    position: relative;
    width: 100%;
    height: 8px;
    background: rgba(var(--rgb-brand-1), 0.08);
    border-radius: 999px;
    overflow: hidden;
    margin-top: 0.5rem;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-brand-1), #9333ea);
    border-radius: 999px;
    transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    z-index: 2;
  }

  .progress-glow {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: shine 2s infinite;
  }

  @keyframes shine {
    from { transform: translateX(-100%); }
    to { transform: translateX(100%); }
  }

  .progress-label {
    font-size: 0.9rem;
    color: var(--color-text-alt);
    font-weight: 700;
    font-family: var(--font-mono, monospace);
  }

  /* ── Error ── */
  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 4rem 1rem;
  }

  .error-icon {
    font-size: 3rem;
  }

  .error-text {
    font-size: 1.1rem;
    color: var(--color-text);
    text-align: center;
  }

  .back-btn {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.6rem 1.6rem;
    background: var(--color-brand-1);
    color: var(--color-white);
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s var(--ease-out-expo);
  }

  .back-btn:hover {
    filter: brightness(1.1);
    transform: scale(1.04);
  }

  /* ── Results Container ── */
  .results-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Thought Process (Deep Thinking) ── */
  .thought-container {
    background: var(--color-surface);
    border: 1px solid rgba(var(--rgb-brand-1), 0.15);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .thought-header {
    width: 100%;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(var(--rgb-brand-1), 0.03);
    border: none;
    border-bottom: 1px solid rgba(var(--rgb-brand-1), 0.1);
    cursor: pointer;
    text-align: left;
    transition: background 0.2s;
  }

  .thought-header:hover {
    background: rgba(var(--rgb-brand-1), 0.06);
  }

  .thought-icon {
    font-size: 1.2rem;
    filter: drop-shadow(0 0 8px rgba(var(--rgb-brand-1), 0.4));
  }

  .thought-title {
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-brand-1);
    flex-grow: 1;
  }

  .thought-arrow {
    width: 10px;
    height: 10px;
    border-right: 2px solid var(--color-brand-1);
    border-bottom: 2px solid var(--color-brand-1);
    transform: rotate(-135deg);
    transition: transform 0.3s;
    margin-right: 0.5rem;
  }

  .thought-container.is-collapsed .thought-arrow {
    transform: rotate(45deg);
  }

  .thought-container.is-collapsed .thought-content {
    display: none;
  }

  .thought-content {
    padding: 1.2rem;
  }

  .thought-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .thought-section {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    min-width: 0; /* Crucial for preventing grid item overflow */
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-alt);
    opacity: 0.8;
  }

  .section-a {
    grid-column: 1 / 2;
    border-right: 1px solid rgba(var(--rgb-brand-1), 0.12);
    padding-right: 1.2rem;
  }

  .section-b {
    grid-column: 2 / 3;
    padding-left: 0.2rem;
    position: relative;
    max-height: 0; /* Important: allow grid to define row height, then fill it */
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }

  .scroll-wrapper-b {
    flex: 1;
    overflow-y: auto;
    padding-right: 0.8rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(var(--rgb-brand-1), 0.2) transparent;
  }

  .scroll-wrapper-b::-webkit-scrollbar {
    width: 6px;
  }

  .scroll-wrapper-b::-webkit-scrollbar-track {
    background: transparent;
  }

  .scroll-wrapper-b::-webkit-scrollbar-thumb {
    background: rgba(var(--rgb-brand-1), 0.2);
    border-radius: 10px;
  }

  .section-c {
    grid-column: 1 / 3;
    border-top: 1px solid rgba(var(--rgb-brand-1), 0.15);
    padding-top: 1.2rem;
    margin-top: 0.5rem;
    min-height: auto;
  }

  @media (max-width: 640px) {
    .check-page {
      padding-top: 60px;
      padding-left: 0 !important;
      padding-right: 0 !important;
      overflow-x: hidden;
    }
    .u-container {
      padding: 0 !important;
      margin: 0 !important;
      max-width: 100% !important;
      width: 100% !important;
    }
    .results-container {
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      gap: 1rem;
    }
    .thought-container {
      border-radius: 0;
      border-left: none;
      border-right: none;
      width: 100vw !important;
    }
    .thought-content {
      padding: 0.75rem;
      width: 100%;
      box-sizing: border-box;
    }
    .thought-grid {
      grid-template-columns: 1fr;
      width: 100%;
    }
    .section-a, .section-b, .section-c {
      grid-column: 1 / 2;
      border-right: none;
      padding-right: 0;
      padding-left: 0;
      width: 100%;
      min-width: 0;
    }
    .section-b {
      border-top: 1px solid rgba(var(--rgb-brand-1), 0.12);
      padding-top: 1.2rem;
      max-height: none;
      min-height: auto;
    }
    .scroll-wrapper-b {
      overflow-y: visible;
      padding-right: 0;
    }
    .section-c {
      max-height: none;
    }
    .col-title {
      margin-left: 0.8rem;
      margin-right: 0.8rem;
    }
    .summary-box {
      margin-left: 0.5rem;
      margin-right: 0.5rem;
      padding: 1.2rem;
    }
  }

  /* ── Chart Styles ── */
  .mini-table {
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(var(--rgb-brand-1), 0.1);
    padding-bottom: 1rem;
  }

  .charts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .chart-item {
    background: var(--color-bg-alt);
    border-radius: 12px;
    padding: 1rem;
    border: 1px solid rgba(var(--rgb-brand-1), 0.08);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    display: none; /* Changed from flex */
    flex-direction: column;
    gap: 0.8rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .chart-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .chart-item:hover {
    background: rgba(var(--rgb-brand-1), 0.05);
    border-color: rgba(var(--rgb-brand-1), 0.2);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(var(--rgb-brand-1), 0.08);
  }

  .chart-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-alt);
    text-align: center;
  }

  .chart-canvas-wrapper {
    position: relative;
    height: 280px;
    width: 100%;
