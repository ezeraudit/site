</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  // ── i18n strings passed from Astro ──
  const metaEl = document.querySelector('meta[name="check-i18n"]');
  const i18n = metaEl ? JSON.parse(metaEl.getAttribute('content') || '{}') : {};

  // ── Helper: get lang from URL ──
  const isEn = window.location.pathname.startsWith('/en');
  const lang = isEn ? 'en' : 'zh-CN';

  // ── Grab URL params ──
  const params = new URLSearchParams(window.location.search);
  const code = params.get('code');
  const year = params.get('year');
  const period = params.get('period');
  const preview = params.get('preview');

  // DOM refs
  const loadingEl = document.getElementById('loading-container')!;
  const errorEl = document.getElementById('error-container')!;
  const resultsEl = document.getElementById('results-container')!;
  const pageTitleEl = document.getElementById('page-title')!;
  const loadingTextEl = document.getElementById('loading-text')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressLabel = document.getElementById('progress-label')!;
  const errorTextEl = document.getElementById('error-text')!;

  const thoughtContainer = document.getElementById('thought-container')!;
  const thoughtToggle = document.getElementById('thought-toggle')!;
  const textB = document.getElementById('text-b') as HTMLElement;
  const textC = document.getElementById('text-c') as HTMLElement;
  const summaryText = document.getElementById('summary-text')!;
  const finalResultText = document.getElementById('final-result-text')!;

  // ── Placeholder Manager for B & C ──
  class PlaceholderManager {
    private interval: any = null;
    private messages: string[] = [];
    private currentIndex = 0;

    constructor(private element: HTMLElement, messages: string[]) {
      this.messages = messages;
    }

    start() {
      if (this.messages.length === 0) return;
      this.element.classList.add('is-placeholder');
      this.element.textContent = this.messages[0];
      this.interval = setInterval(() => {
        this.currentIndex = (this.currentIndex + 1) % this.messages.length;
        this.element.textContent = this.messages[this.currentIndex];
      }, 3000);
    }

    stop() {
      if (this.interval) {
        clearInterval(this.interval);
        this.interval = null;
        this.element.textContent = '';
        this.element.classList.remove('is-placeholder');
      }
    }

    isActive() {
      return this.interval !== null;
    }
  }

  const bcMessages = lang === 'zh-CN' ? [
    '正在多维核对财报钩稽关系...',
    '正在执行收入截止性测试...',
    '正在分析营运资金周转效率...',
    '正在评估资产减值准备计提...',
    '正在核算加权平均资本成本...',
    '正在比对历史趋势异常波动...',
    '正在检验研发投入资本化比例...',
    '正在审计关联方交易公允性...',
    '正在验证存货周转率合理性...',
    '正在解析财报附注深度内涵...',
    '正在扫描潜在表外融资风险...'
  ] : [
    'Cross-checking financial statement integrity...',
    'Performing revenue cutoff tests...',
    'Analyzing working capital efficiency...',
    'Evaluating asset impairment provisions...',
    'Calculating Weighted Average Cost of Capital...',
    'Inspecting historical trend anomalies...',
    'Verifying R&D capitalization ratios...',
    'Auditing related-party transaction fairness...',
    'Validating inventory turnover logic...',
    'Parsing deep insights from footnotes...',
    'Scanning for off-balance sheet risks...'
  ];

  const placeholderB = new PlaceholderManager(textB, bcMessages);
  const placeholderC = new PlaceholderManager(textC, bcMessages);

  // Initialize Summary Placeholder
  summaryText.textContent = lang === 'zh-CN' ? '正在等待分析完成...' : 'Waiting for analysis to complete...';
  summaryText.classList.add('is-placeholder');

  // Toggle thought process
  thoughtToggle.addEventListener('click', () => {
    thoughtContainer.classList.toggle('is-collapsed');
    thoughtToggle.setAttribute('aria-expanded', String(!thoughtContainer.classList.contains('is-collapsed')));
  });

  // ── Chart Manager ──
  class ChartManager {
    private charts: Record<string, any> = {};

    private getOptions(title: string, suffix: string = '') {
      const isDark = document.documentElement.classList.contains('dark');
      const textColor = isDark ? '#94a3b8' : '#64748b';
      const gridColor = isDark ? 'rgba(148, 163, 184, 0.1)' : 'rgba(100, 116, 139, 0.1)';
      const brandColor = 'rgba(124, 58, 237, 1)'; // var(--color-brand-1) approximation

      return {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            mode: 'index',
            intersect: false,
            filter: (item: any) => item.datasetIndex === 0,
            callbacks: {
              label: (context: any) => {
                let label = context.dataset.label || '';
                if (label) label += ': ';
                if (context.parsed.y !== null) {
                  label += context.parsed.y.toLocaleString() + suffix;
                }
                return label;
              }
            }
          }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: textColor, font: { size: 10 } }
          },
          y: {
            grid: { color: gridColor },
            ticks: { 
              color: textColor, 
              font: { size: 10 },
              callback: (value: any) => {
                if (suffix === '%') return value + '%';
                if (value >= 100000000) return (value / 100000000).toFixed(1) + '亿';
                if (value >= 10000) return (value / 10000).toFixed(0) + '万';
                return value;
              }
            }
          }
        }
      };
    }

    render(id: string, data: any[], label: string, suffix: string = '') {
      const ctx = document.getElementById(id) as HTMLCanvasElement;
      if (!ctx) return;

      // Reveal the parent container
      const container = ctx.closest('.chart-item') as HTMLElement;
      if (container) {
        container.style.display = 'flex';
        // Minor delay to trigger CSS transition
        setTimeout(() => container.classList.add('is-visible'), 10);
      }

      // Ensure the section itself is visible
      const sectionA = document.querySelector('.section-a');
      if (sectionA) sectionA.classList.remove('hidden');

      if (this.charts[id]) {
        this.charts[id].destroy();
      }

      // @ts-ignore (Chart.js via CDN)
      this.charts[id] = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: data.map(d => d.period),
          datasets: [
            {
              label: label,
              data: data.map(d => d.value),
              backgroundColor: 'rgba(124, 58, 237, 0.2)',
              borderColor: 'rgba(124, 58, 237, 0.8)',
              borderWidth: 1,
              order: 2,
              borderRadius: 4,
            },
            {
              label: lang === 'zh-CN' ? '趋势' : 'Trend',
              data: data.map(d => d.value),
              type: 'line',
              borderColor: 'rgba(124, 58, 237, 1)',
              borderWidth: 2,
              pointRadius: 3,
              pointBackgroundColor: 'rgba(124, 58, 237, 1)',
              tension: 0.4,
              order: 1
            }
          ]
        },
        options: this.getOptions(label, suffix)
      });
    }
  }

  const chartManager = new ChartManager();

  /**
   * Simple Typewriter effect for streaming feel
   */
  class Typewriter {
    private queue: { text?: string; html?: string }[] = [];
    private isRunning = false;
    private speed = 15; // ms per char
    private scrollParent: HTMLElement | null = null;

    constructor(private element: HTMLElement) {
      this.scrollParent = element.closest('.scroll-wrapper-b') || element.closest('.text-output');
    }

    write(text: string) {
      if (!text) return;
      this.queue.push({ text });
      if (!this.isRunning) this.run();
    }

    writeHTML(html: string) {
      if (!html) return;
      this.queue.push({ html });
      if (!this.isRunning) this.run();
    }

    private async run() {
      this.isRunning = true;
      this.element.classList.remove('is-done');
      while (this.queue.length > 0) {
        const item = this.queue.shift();
        if (!item) continue;

        if (item.html) {
          this.element.insertAdjacentHTML('beforeend', item.html);
          this.autoScroll();
          await new Promise(r => setTimeout(r, 200));
        } else if (item.text) {
          const chars = item.text.split('');
          for (const char of chars) {
            this.element.insertAdjacentText('beforeend', char);
            if (char === '\n') this.autoScroll();
            await new Promise(r => setTimeout(r, this.speed));
          }
        }
        this.autoScroll();
      }
      this.isRunning = false;
      this.element.classList.add('is-done');
    }

    private autoScroll() {
      if (this.scrollParent) {
        this.scrollParent.scrollTo({
          top: this.scrollParent.scrollHeight,
          behavior: 'smooth'
        });
      }
    }

    done() {
      this.element.classList.add('is-done');
    }
  }

  const writers = {
    b: new Typewriter(textB),
    c: new Typewriter(textC),
    summary: new Typewriter(summaryText),
  };

  async function renderCharts(history: any[]) {
    if (!history || history.length === 0) return;
    
    // Sort to show chronological order
    const sorted = [...history].sort((a, b) => {
        return a.reporting_period.localeCompare(b.reporting_period);
    });

    const revenueData = sorted.map(h => ({ period: h.reporting_period, value: h.revenue }));
    const profitData = sorted.map(h => ({ period: h.reporting_period, value: h.net_profit }));
    const marginData = sorted.map(h => ({ period: h.reporting_period, value: h.gross_margin }));
    const debtData = sorted.map(h => ({ period: h.reporting_period, value: h.debt_to_asset }));

    const chartConfigs = [
      { id: 'chart-revenue', data: revenueData, label: formatKey('revenue'), suffix: '' },
      { id: 'chart-profit', data: profitData, label: formatKey('net_profit'), suffix: '' },
      { id: 'chart-margin', data: marginData, label: formatKey('gross_margin'), suffix: '%' },
      { id: 'chart-debt', data: debtData, label: formatKey('debt_to_asset'), suffix: '%' },
    ];

    for (const config of chartConfigs) {
      if (config.data.some(d => d.value !== null && d.value !== undefined)) {
        chartManager.render(config.id, config.data, config.label, config.suffix);
        await new Promise(r => setTimeout(r, 600)); // Sequential delay for streaming feel
      }
    }
  }

  function formatSymbol(codeParam: string | null): string {
    if (!codeParam) return '';
    if (codeParam.includes('.')) return codeParam;
    const match = codeParam.match(/^([a-z]+)(\d+)$/i);
    if (match) {
      return `${match[2]}.${match[1].toUpperCase()}`;
    }
    return codeParam;
  }

  function formatKey(key: string): string {
    const map: Record<string, string> = {
      'name': lang === 'zh' ? '公司名称' : 'Company Name',
      'ticker': lang === 'zh' ? '股票代码' : 'Ticker',
      'reporting_period': lang === 'zh' ? '报告期' : 'Period',
      'release_date': lang === 'zh' ? '发布日期' : 'Release Date',
      'revenue': lang === 'zh' ? '营业收入' : 'Revenue',
      'net_profit': lang === 'zh' ? '净利润' : 'Net Profit',
      'gross_margin': lang === 'zh' ? '毛利率' : 'Gross Margin',
      'roe': lang === 'zh' ? 'ROE' : 'ROE',
      'total_assets': lang === 'zh' ? '总资产' : 'Total Assets',
      'total_liabilities': lang === 'zh' ? '总负债' : 'Total Liabs',
      'debt_to_asset': lang === 'zh' ? '资产负债率' : 'Debt Ratio',
    };
    return map[key] || key;
  }

  function showError(msg?: string) {
    if (msg) console.error('[Analysis Error Detail]:', msg);
    loadingEl.classList.add('hidden');
    errorEl.classList.remove('hidden');

    const backLink = document.getElementById('back-link');
    const upgradeLink = document.getElementById('upgrade-link');

    // If it's a quota error, swap buttons
    if (msg && msg.toLowerCase().includes('quota exceeded')) {
      errorTextEl.textContent = i18n['quota.limit_reached'].replace('{h}', '24'); // Defaulting to 24h as a placeholder if not known
      if (backLink) backLink.classList.add('hidden');
      if (upgradeLink) upgradeLink.classList.remove('hidden');
    } else {
      // Normal error
      if (backLink) backLink.classList.remove('hidden');
      if (upgradeLink) upgradeLink.classList.add('hidden');
    }
  }

  async function typeText(el: HTMLElement, text: string, speed = 20) {
    if (!el || !text) return;
    const chars = text.split('');
    for (const char of chars) {
      el.textContent += char;
      if (char === '\n' || char === '。' || char === '.') {
        const scrollParent = el.closest('.scroll-wrapper-b') || el.closest('.text-output');
        if (scrollParent) scrollParent.scrollTo({ top: scrollParent.scrollHeight, behavior: 'smooth' });
      }
      await new Promise(r => setTimeout(r, speed));
    }
    // Final scroll
    const scrollParent = el.closest('.scroll-wrapper-b') || el.closest('.text-output');
    if (scrollParent) scrollParent.scrollTo({ top: scrollParent.scrollHeight, behavior: 'smooth' });
  }

  function setProgress(pct: number, label?: string) {
    progressBar.style.width = pct + '%';
    progressLabel.textContent = pct + '%';
    if (label) loadingTextEl.textContent = label;
  }

  /**
   * Process a single event from the stream
   */
  async function processEvent(item: any) {
    if (!item) return;
    console.log('[Stream Event]', item);
    const { producer, event, data } = item;
    const value = item.value || data; // Handle alternate field names

    if (event === 'a_data') {
      const { label, data: chartData, type, suffix } = value;
      if (label && chartData) {
        const idMap: Record<string, string> = {
          'Revenue': 'chart-revenue',
          '营业收入': 'chart-revenue',
          'Net Profit': 'chart-profit',
          '净利润': 'chart-profit',
          'Gross Margin': 'chart-margin',
          '毛利率': 'chart-margin',
          'Debt Ratio': 'chart-debt',
          '资产负债率': 'chart-debt'
        };
        const id = idMap[label] || `chart-${label.toLowerCase()}`;
        chartManager.render(id, chartData.map((d:any) => typeof d === 'object' ? d : {period: '', value: d}), label, suffix || '');
        await new Promise(r => setTimeout(r, 400));
      }
      return;
    }

    // Normalize producer name (A, B, C or normalizer, analyzer, auditor)
    const p = (producer || '').toUpperCase();

    if ((p === 'A' || p === 'NORMALIZER') && (event === 'a_normalized' || event === 'data')) {
      const d = data || item.data;
      if (!d) return;
      
      const { company, report, income_statement, balance_sheet, key_ratios, history_12q } = d;
      
      if (history_12q) {
        await renderCharts(history_12q);
      }

      if (company) {
        const companyName = company.name || '';
        let periodText = company.reporting_period || '';
        if (lang === 'zh-CN' && periodText.toLowerCase().includes('fy')) {
          periodText = periodText.replace(/fy/i, '年度');
        }

        if (companyName) {
          const titleSuffix = lang === 'zh-CN' ? '财报分析' : 'Financial Report Analysis';
          pageTitleEl.textContent = `${companyName} (${periodText}) ${titleSuffix}`;
          document.title = `${companyName} (${periodText}) ${titleSuffix} - Ezer Audit`;
        }
      }
    }

    if ((p === 'B' || p === 'ANALYZER')) {
      if (placeholderB.isActive()) placeholderB.stop();
      const d = data || item.data;
      if (!d) return;

      if (event === 'b_progress') {
        const stepPrefix = lang === 'zh-CN' ? '正在' : 'Analyzing';
        writers.b.writeHTML(`<div class="progress-update"><i>› ${stepPrefix} ${d.task || d.step || (lang === 'zh-CN' ? '执行分析' : 'Performing Analysis')}...</i></div>`);
        return;
      }

      if (event === 'b_card' || event === 'analysis') {
        const card = document.createElement('div');
        card.className = 'analysis-card';
        
        if (d.title) {
          const h3 = document.createElement('h3');
          h3.textContent = d.title;
          card.appendChild(h3);
        }
        
        const conclusion = document.createElement('p');
        conclusion.className = 'conclusion';
        card.appendChild(conclusion);
        
        writers.b.element.appendChild(card);
        if (d.conclusion) await typeText(conclusion, d.conclusion, 15);

        const detailsList = document.createElement('ul');
        detailsList.className = 'details-list';
        card.appendChild(detailsList);

        const fields = [
          { key: 'evidence', label: lang === 'zh-CN' ? '依据' : 'Evidence' },
          { key: 'cross_checks', label: lang === 'zh-CN' ? '交叉验证' : 'Cross-checks' },
          { key: 'counterpoints', label: lang === 'zh-CN' ? '反向观点' : 'Counterpoints' }
        ];

        for (const field of fields) {
          const val = d[field.key];
          if (val && val.length) {
            const li = document.createElement('li');
            li.innerHTML = `<span class="label">${field.label}:</span> `;
            const textSpan = document.createElement('span');
            li.appendChild(textSpan);
            detailsList.appendChild(li);
            const text = Array.isArray(val) ? val.join(', ') : val;
            await typeText(textSpan, text, 10);
          }
        }

        if (d.investor_implication) {
          const implication = document.createElement('p');
          implication.className = 'implication';
          const labelImplication = lang === 'zh-CN' ? '投资启示' : 'Investor Implication';
          implication.innerHTML = `<span class="label">${labelImplication}:</span> `;
          const textSpan = document.createElement('span');
          implication.appendChild(textSpan);
          card.appendChild(implication);
          await typeText(textSpan, d.investor_implication, 15);
        }
      }
    }

    if ((p === 'C' || p === 'AUDITOR')) {
      if (placeholderC.isActive()) placeholderC.stop();
      const d = data || item.data;
      if (!d) return;

      if (event === 'c_progress') {
        const stepPrefix = lang === 'zh-CN' ? '正在' : 'Analyzing';
        writers.c.writeHTML(`<div class="progress-update"><i>› ${stepPrefix} ${d.task || d.step || (lang === 'zh-CN' ? '执行审计' : 'Performing Audit')}...</i></div>`);
        return;
      }

      if (event === 'c_challenge') {
        const div = document.createElement('div');
        div.className = 'audit-item challenge';
        const labelChallenge = lang === 'zh-CN' ? '审计挑战' : 'Audit Challenge';
        div.innerHTML = `<div class="audit-icon-text">⚠️ ${labelChallenge} (${d.severity || 'MEDIUM'})</div>`;
        const content = document.createElement('div');
        content.className = 'audit-content';
        div.appendChild(content);
        if (d.target_card_id) {
          const meta = document.createElement('div');
          meta.className = 'audit-meta';
          const labelTarget = lang === 'zh-CN' ? '针对' : 'Target';
          meta.textContent = `${labelTarget}: ${d.target_card_id}`;
          div.appendChild(meta);
        }
        writers.c.element.appendChild(div);
        if (d.issue) await typeText(content, d.issue, 15);
      }

      if (event === 'c_resolved' || event === 'audit') {
        const div = document.createElement('div');
        div.className = 'audit-item resolved';
        const labelResolved = lang === 'zh-CN' ? '审计通过' : 'Audit Resolved';
        div.innerHTML = `<div class="audit-icon-text">✅ ${labelResolved}</div>`;
        const content = document.createElement('div');
        content.className = 'audit-content';
        div.appendChild(content);
        if (d.target_card_id) {
          const meta = document.createElement('div');
          meta.className = 'audit-meta';
          const labelFix = lang === 'zh-CN' ? '解决项' : 'Fixed';
          meta.textContent = `${labelFix}: ${d.target_card_id}`;
          div.appendChild(meta);
        }
        writers.c.element.appendChild(div);
        const textToType = d.rationale || d.content || d.text || '';
        if (textToType) await typeText(content, textToType, 15);
      }
    }

    if (event === 'final_summary' || event === 'summary') {
      if (summaryText.classList.contains('is-placeholder')) {
        summaryText.textContent = '';
        summaryText.classList.remove('is-placeholder');
      }
      const d = data || item.data;
      if (d) {
        const text = d.summary || d.content || d.text || '';
        await typeText(summaryText, text, 15);
      }
    }

    if (event === 'final_result' || event === 'result') {
      const d = data || item.data;
      if (d) {
        finalResultText.classList.remove('hidden');
        const prefix = lang === 'zh-CN' ? '最终结果：' : 'Final Result: ';
        finalResultText.textContent = prefix + (d.final_status || d.status || d.result || '');
      }
    }

    if (event === 'error' || event === 'task_failed') {
      const d = data || item.data;
      const msg = d?.message || d?.error || 'Unknown error occurred';
      showError(msg);
      return;
    }
  }

  /**
   * Main logic to handle simulated stream
   */
  async function processStream(stream: any[]) {
    loadingEl.classList.add('hidden');
    resultsEl.classList.remove('hidden');

    // Start placeholders
    placeholderB.start();
    placeholderC.start();

    for (const item of stream) {
      processEvent(item);
      await new Promise(r => setTimeout(r, 200));
    }
  }

  // ── Main entry point ──
  async function main() {
    let collectedData: any[] = [];
    const cacheKey = `cache:check:${code}:${year}:${period}:${lang}`;

    try {
      // ── Quota Check ──
      // Wait a bit for QuotaBanner to initialize if needed, or check directly
      const session = await window.auth?.getSession();
      if (!preview && session) {
        const { data: plan } = await window.auth.client
          .from('user_plans')
          .select('*')
          .eq('uid', session.user.id)
          .single();
        
        if (plan && plan.plan_type === 'free') {
          const today = new Date().toISOString().split('T')[0];
          let remaining = plan.quota_remaining;
          if (plan.last_used_date !== today) remaining = 3;

          if (remaining <= 0) {
            const now = new Date();
            const tomorrow = new Date(now);
            tomorrow.setUTCHours(24, 0, 0, 0);
            const hours = Math.ceil((tomorrow - now) / 3600000);
            
            const limitMsg = i18n['quota.limit_reached'].replace('{h}', hours.toString());
            const upgradeNow = i18n['quota.upgrade_now'];
            const premiumUrl = lang === 'en' ? '/en/premium/?from=exceed' : '/premium/?from=exceed';
            
            errorTextEl.innerHTML = `${limitMsg} <a href="${premiumUrl}" style="color:var(--color-brand-1);font-weight:bold;">${upgradeNow}</a>`;
            showError();
            return;
          }
        }
      }

      const apiParams = new URLSearchParams(window.location.search);
      apiParams.set('lang', lang);

      console.log('--- Initiating Audit (Locally checking cache first) ---');
      
      let currentProgress = 5;
      const startTime = Date.now();
      const progressTimer = setInterval(() => {
        const elapsed = Date.now() - startTime;
        if (elapsed < 1200) {
          currentProgress = 5 + (45 * (elapsed / 1200));
        } else if (elapsed < 10000) {
          currentProgress = 50 + (45 * ((elapsed - 1200) / 8800));
        } else {
          currentProgress = 95;
        }
        const label = currentProgress < 50 
          ? (lang === 'zh' ? '正在连接安全审计服务器...' : 'Connecting to audit server...')
          : (lang === 'zh' ? '正在深度穿透财务数据...' : 'Deeply analyzing financial data...');
        setProgress(Math.floor(currentProgress), label);
      }, 50);

      const cleanup = () => clearInterval(progressTimer);

      try {
        const localResp = await fetch(`/api/check?${apiParams.toString()}`);
      const contentType = localResp.headers.get('content-type');

      // (A) Cache Hit Case: Process as a stream as before
      if (contentType && contentType.includes('application/x-ndjson')) {
        console.log('Cache Hit: Streaming from local API...');
        cleanup(); 
        await handleResponseStream(localResp);
        return;
      }

      // (B) Cache Miss or Error Case: Handle JSON response
      const serverResult = await localResp.json();
      
      if (serverResult.error) {
        throw new Error(serverResult.error);
      }

      // (C) Direct Fetch Case: Bypassing Vercel timeouts
      if (serverResult.action === 'direct_fetch') {
        const { api, token, params } = serverResult.config;
        console.log('Cache Miss: Initiating DIRECT fetch to backend to avoid 10s limits...');

        // Step 1: Initialize Task (POST /api/tasks)
        const taskResp = await fetch(api, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
            body: JSON.stringify(params)
        });
        if (!taskResp.ok) {
            const errTxt = await taskResp.text();
            throw new Error(`Task init failed: ${taskResp.status} ${errTxt}`);
        }
        
        const taskData = await taskResp.json();
        const taskId = taskData.task_id;
        const rawStreamUrl = taskData.stream_url;
        const rawResultUrl = taskData.result_url;

        if (!rawStreamUrl) throw new Error('No stream_url from backend');
        const streamUrl = rawStreamUrl.startsWith('http') ? rawStreamUrl : `https://api.ezer.cc${rawStreamUrl}`;
        const resultUrl = rawResultUrl ? (rawResultUrl.startsWith('http') ? rawResultUrl : `https://api.ezer.cc${rawResultUrl}`) : null;

        // Step 2: Stream from backend with a 5-minute initial connection timeout
        const controller = new AbortController();
        let isSuccessfullyCompleted = false;
        let timeoutId = setTimeout(() => {
          controller.abort();
          showError(lang === 'zh' ? '分析连接超时，请稍后刷新重试' : 'Connection timeout, please refresh later');
        }, 300000);

        console.log('Connecting to direct stream:', streamUrl);
        const streamResp = await fetch(streamUrl, {
            headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'text/event-stream' },
            signal: controller.signal
        });

        if (!streamResp.ok) {
            clearTimeout(timeoutId);
            throw new Error(`Stream download failed: ${streamResp.status}`);
        }
        
        cleanup(); 
        // Handle SSE stream using the pattern from public/examples/frontend_call_example_v1.md
        await handleResponseStream(
            streamResp, 
            (item) => {
                collectedData.push(item);
                // Check if this is a completion event
                if (item.event === 'final_result' || item.event === 'result') {
                    isSuccessfullyCompleted = true;
                }
            }, 
            true, // isSSE
            () => {
                // onFirstChunk: Clear initial timeout and start a new 5-minute data transfer timeout
                console.log('First chunk received. Resetting timeout for data transfer...');
                clearTimeout(timeoutId);
                timeoutId = setTimeout(() => {
                    controller.abort();
                    showError(lang === 'zh' ? '报告生成超时，请稍后刷新重试' : 'Report generation timeout, please refresh later');
                }, 300000);
            }
        );

        clearTimeout(timeoutId);

        // Step 3: Fetch Final Result if available (to ensure completeness)
        if (resultUrl && collectedData.length > 0) {
            console.log('Fetching final result for data verification...');
            try {
                const finalResp = await fetch(resultUrl, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (finalResp.ok) {
                    const finalData = await finalResp.json();
                    // Process final result if needed, e.g., to backfill missing fields
                    console.log('Final Result Data:', finalData);
                    // Standard backend format is to put everything in final_payload
                    const payload = finalData.final_payload;
                    if (payload) {
                        // Optionally merge or sync with collectedData
                    }
                }
            } catch (e) {
                console.error('Failed to fetch final result:', e);
            }
        }

        // Step 4: Backfill Cache only if successfully completed
        if (isSuccessfullyCompleted && collectedData.length > 0) {
            console.log('Analysis complete and verified. Backfilling cache...');
            fetch('/api/check', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cacheKey, data: collectedData })
            }).catch(e => console.error('Cache backfill failed', e));
        }
      }
    } finally {
      cleanup();
    }
  } catch (err: any) {
    cleanup();
    if (err.name === 'AbortError') {
      // Already handled by timer above, but safety catch
    } else {
      showError(err.message);
    }
  }
}

  /**
   * Helper to handle stream decoding and line processing
   * Supports both NDR-JSON and SSE (with data: prefix and \n\n separator)
   */
  async function handleResponseStream(
    response: Response, 
    onEachItem?: (item: any) => void, 
    isSSE = false,
    onFirstChunk?: () => void
  ) {
    if (preview === 'true') {
      // Hijack and speed up to 99%
      const startPct = parseInt(progressLabel.textContent || '50');
      const duration = 3000;
      const startTime = Date.now();
      
      const previewTimer = setInterval(() => {
        const elapsed = Date.now() - startTime;
        const p = Math.min(1, elapsed / duration);
        const currentPct = Math.floor(startPct + (99 - startPct) * p);
        
        const labels = lang === 'zh-CN' 
          ? ['数据链路验证成功...', '正在构建归一化大模型...', '正在执行交叉审计穿透...', '财务诊断报告生成中...']
          : ['Link verified...', 'Building AI model...', 'Executing cross-audit...', 'Generating report...'];
        const labelIdx = Math.min(labels.length - 1, Math.floor(p * labels.length));
        
        setProgress(currentPct, labels[labelIdx]);
        if (p >= 1) clearInterval(previewTimer);
      }, 50);

      await new Promise(r => setTimeout(r, duration));
      clearInterval(previewTimer);
    }

    loadingEl.classList.add('hidden');
    resultsEl.classList.remove('hidden');
    // Ensure all timers are truly gone when we show results
    if (window.loadingInterval) clearInterval(window.loadingInterval);

    placeholderB.start();
    placeholderC.start();

    if (!response.body) throw new Error('Response body is empty');
    
    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    let isFirstChunk = true;

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      
      if (isFirstChunk) {
        isFirstChunk = false;
        if (onFirstChunk) onFirstChunk();
      }

      buffer += decoder.decode(value, { stream: true });

      if (isSSE) {
        // SSE Logic (Uses \n\n as boundary)
        while (true) {
          const boundary = buffer.indexOf('\n\n');
          if (boundary === -1) break;

          const rawEvent = buffer.slice(0, boundary);
          buffer = buffer.slice(boundary + 2);

          for (const line of rawEvent.split('\n')) {
            if (!line.startsWith('data: ')) continue;
            const dataStr = line.slice(6).trim();
            if (!dataStr || dataStr === '[DONE]') continue;

            try {
              const item = JSON.parse(dataStr);
              if (onEachItem) onEachItem(item);
              await processEvent(item);
            } catch (e) {
              console.error('SSE Line parse error:', dataStr, e);
            }
          }
        }
      } else {
        // Standard NDR-JSON Logic (Uses \n as boundary)
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed || trimmed.startsWith(':')) continue;
          let dataStr = trimmed;
          if (dataStr.startsWith('data: ')) dataStr = dataStr.substring(6).trim();
          if (!dataStr || dataStr === '[DONE]') continue;

          try {
            const item = JSON.parse(dataStr);
            if (onEachItem) onEachItem(item);
            await processEvent(item);
          } catch (e) { 
            console.error('NDR JSON Line parse error:', dataStr, e); 
          }
        }
      }
    }

    // Process leftover buffer
    if (buffer.trim()) {
        const trimmed = buffer.trim();
        let dataStr = trimmed;
        if (dataStr.startsWith('data: ')) dataStr = dataStr.substring(6).trim();
        if (dataStr && dataStr !== '[DONE]') {
            try {
                const item = JSON.parse(dataStr);
                if (onEachItem) onEachItem(item);
                await processEvent(item);
            } catch (e) {}
        }
    }
  }

  // ── Scroll Behavior for Area B/C (Desktop) ──
  const setupAreaScroll = () => {
    const wrappers = document.querySelectorAll('.scroll-wrapper-b');
    wrappers.forEach(wrapper => {
      wrapper.addEventListener('wheel', (e: any) => {
        if (window.innerWidth > 640) {
          const { scrollTop, scrollHeight, clientHeight } = wrapper;
          const isAtTop = scrollTop === 0;
          const isAtBottom = Math.abs(scrollTop + clientHeight - scrollHeight) < 2;

          const scrollingDown = e.deltaY > 0;
          const scrollingUp = e.deltaY < 0;

          // If we are NOT at the boundary in the direction of scrolling, 
          // stop propagation to prevent Lenis from scrolling the page.
          if ((scrollingDown && !isAtBottom) || (scrollingUp && !isAtTop)) {
            e.stopPropagation();
          }
        }
      }, { passive: true });
    });
  };
  setupAreaScroll();

  main();
</script>
