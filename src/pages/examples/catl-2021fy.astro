---
import Layout from "../../layouts/Layout.astro";

const base = "/examples/catl-300750-2021fy";
const files = [
  { label: "Request JSON", href: `${base}/request.json` },
  { label: "A Normalized JSON", href: `${base}/a_normalized.json` },
  { label: "MX Supplement Summary", href: `${base}/mx_summary.json` },
  { label: "Detailed Frontend Stream", href: `${base}/frontend_stream_detailed.jsonl` },
  { label: "Final Result JSON", href: `${base}/final_result.json` },
  { label: "Run Summary JSON", href: `${base}/run_summary.json` },
];
---

<Layout title="CATL 2021FY Example">
  <section class="example-shell">
    <p class="eyebrow">Ezer Example</p>
    <h1>宁德时代 2021 年报</h1>
    <p class="lede">
      最新案例基于公开东财结构化财务数据 + 妙想 searchData 补充源，
      A 使用确定性标准化，B/C 使用 Gemini 代理完成分析与审计复核。
    </p>
    <div class="meta-grid">
      <div><strong>Code</strong><span>300750.SZ</span></div>
      <div><strong>Period</strong><span>FY 2021</span></div>
      <div><strong>Final</strong><span>PASS</span></div>
      <div><strong>Total</strong><span>133.459s</span></div>
    </div>
    <ul class="file-list">
      {files.map((file) => (
        <li><a href={file.href}>{file.label}</a></li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .example-shell {
    width: min(920px, calc(100% - 2rem));
    margin: 5rem auto 7rem;
    padding: 2.5rem;
    border: 1px solid color-mix(in srgb, var(--color-text), transparent 86%);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-brand-1), white 82%), transparent 65%),
      color-mix(in srgb, var(--color-bg), white 8%);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    opacity: 0.7;
    margin-bottom: 0.8rem;
  }

  h1 {
    margin: 0 0 0.8rem;
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 0.95;
  }

  .lede {
    max-width: 62ch;
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .meta-grid div {
    padding: 1rem;
    background: color-mix(in srgb, var(--color-text), transparent 94%);
  }

  .meta-grid strong,
  .meta-grid span {
    display: block;
  }

  .meta-grid strong {
    font-size: 0.8rem;
    margin-bottom: 0.35rem;
    opacity: 0.65;
    text-transform: uppercase;
  }

  .file-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .file-list a {
    display: block;
    padding: 1rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--color-text), transparent 86%);
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .example-shell {
      padding: 1.4rem;
      margin-top: 3rem;
    }

    .meta-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
