---
// Redirect logic: if logged in and not from internal site, go to search page
const cookies = Astro.request.headers.get('cookie') || '';
const isLoggedIn = cookies.includes('sb-msufgvqofnihylcnxyac-auth-token');

const referer = Astro.request.headers.get('referer');
let isInternal = false;
if (referer) {
  try {
    const url = new URL(referer);
    isInternal = url.hostname.includes('ezer.cc') || url.hostname === 'localhost' || url.hostname === '127.0.0.1';
  } catch (e) {}
}

if (isLoggedIn && !isInternal) {
  return Astro.redirect('/search/');
}

import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import GalleryText from "../components/GalleryText.astro";
import ImageMarquee from "../components/ImageMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Plans from "../components/Plans.astro";
import Introducing from "../components/Introducing.astro";
import GL from "../components/GL.astro";
import GLPlaces from "../components/GlPlaces.astro";

import logo1 from "../assets/astro_transparent.png";
import logo2 from "../assets/azure_transparent.png";
import logo3 from "../assets/bailian_transparent.png";
import logo4 from "../assets/cloudflare_transparent.png";
import logo5 from "../assets/eastmoney_transparent.png";
import logo6 from "../assets/github_transparent.png";
import logo7 from "../assets/huggingface_transparent.png";
