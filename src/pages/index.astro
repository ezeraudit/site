---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import GalleryText from "../components/GalleryText.astro";
import ImageMarquee from "../components/ImageMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Plans from "../components/Plans.astro";
import Statements from "../components/Statements.astro";
import Introducing from "../components/Introducing.astro";
import GL from "../components/GL.astro";
import GLPlaces from "../components/GlPlaces.astro";

import logo1 from "../assets/logoipsum-344.svg";
import logo2 from "../assets/logoipsum-350.svg";
import logo3 from "../assets/logoipsum-345.svg";
import logo4 from "../assets/logoipsum-385.svg";
import logo5 from "../assets/logoipsum-375.svg";
import logo6 from "../assets/logoipsum-378.svg";
import logo7 from "../assets/logoipsum-346.svg";
import logo8 from "../assets/logoipsum-331.svg";
---

<Layout title="首页">
  <HeroHome
    title="构建更快，发布更准。"
    subtitle="你所需要的一切，旨在无缝、明智地设计、管理并交付高质量项目，告别盲目揣测与时间浪费。"
    cta={{
      title: "立即开始",
      url: "#",
    }}
  />

  <Introducing
    title="一个将创意转化为影响力的平台"
    text="从最初的概念到最终的交付，我们的工具简化了协作，消除了瓶颈，让你的团队专注于最重要的事：结果。易于采用，强大可扩展。"
    cta={{
      title: "开始使用",
      url: "#",
    }}
  />

  <StepsTimeline
    title="工作流程"
    items={[
      {
        title: "分钟级部署",
        text: "创建你的工作区，邀请团队成员，轻松配置项目——无需复杂的入门培训或技术设置。",
      },
      {
        title: "无缝协作",
        text: "将沟通、资产和任务集中于一处，确保每个人步调一致并保持高效。",
      },
      {
        title: "交付可衡量的成果",
        text: "实时跟踪进度，优化工作流程，以更清晰的洞察力加快项目交付速度。",
      },
    ]}
  />

  <GalleryText
    title="专为追求清晰与速度的团队打造"
    text="简洁的界面、强大的功能和考究的细节齐聚一处，助力你的团队在保证质量的前提下全速前进。"
    cta={{
      title: "立即尝试",
      url: "#",
    }}
    images={[
      {
        alt: "仪表盘概览",
        src: "/image-1.jpg",
        width: 6000,
        height: 4000,
      },
      {
        alt: "项目协作视图",
        src: "/image-2.jpg",
        width: 2689,
        height: 4032,
      },
      {
        alt: "分析与报告",
        src: "/image-3.jpg",
        width: 3734,
        height: 5359,
      },
    ]}
    marqueeTexts={[
      "创意火花",
      "为速而生",
      "专业信赖",
      "简单透明的价格",
    ]}
  />

  <Statements
    items={[
      {
        title: "为现代团队打造",
        text: "每一项功能都旨在降低复杂性并实现最大化的执行速度。",
      },
      {
        title: "伴你成长",
        text: "无论你是个人创作者还是全球团队，平台都能完美适应你的工作流程。",
      },
      {
        title: "卓越成效",
        text: "减少繁琐工作，加速进展——助你持续交付有意义的成果。",
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "创意火花",
      "为速而生",
      "专业信赖",
      "简单透明的价格",
    ]}
  />

  <Plans
    title="计划与价格"
    subtitle="免费开始，随时升级。无隐藏费用，无长期绑定。"
    items={[
      {
        title: "免费版",
        price: {
          amount: "￥0",
          duration: "月",
        },
        link: {
          title: "免费开始",
          url: "#",
        },
        features: [
          { title: "多达 50 个账户" },
          { title: "无限项目" },
          { title: "在线支持", disabled: true },
          { title: "邮件支持", disabled: true },
          { title: "定制入驻", disabled: true },
        ],
      },
      {
        title: "高级版",
        price: {
          amount: "￥140",
          duration: "月",
        },
        link: {
          title: "开始 14 天试用",
          url: "#",
        },
        features: [
          { title: "多达 50 个账户" },
          { title: "无限项目" },
          { title: "优先在线支持" },
          { title: "邮件支持" },
          { title: "专属入驻协助" },
        ],
      },
    ]}
  />

  <Faqs
    title="常见问题"
    mobileTitle="FAQs"
    subtitle="快速解答最常见疑问。"
    items={[
      {
        question: "这个平台适合谁？",
        answer:
          "它是为想要在不牺牲质量或控制权的情况下快速前进的创作者、初创公司、代理机构和团队打造的。",
      },
      {
        question: "我可以随时升级或降级吗？",
        answer:
          "可以。你可以根据需要随时更改计划，没有罚金或长期合同。",
      },
      {
        question: "免费版真的不收费吗？",
        answer:
          "当然。免费版提供核心功能的完整访问权限，让你可以放心评估平台。",
      },
      {
        question: "我的数据安全吗？",
        answer:
          "是的。我们采用行业标准的安全实践来保护你的数据并确保可靠性。",
      },
      {
        question: "入驻期间提供支持吗？",
        answer:
          "高级版用户可获得专人引导和优先支持，确保平稳起步。",
      },
    ]}
  />

  <ImageMarquee
    images={[
      {
        src: logo1.src,
        alt: "Logo 1",
      },
      {
        src: logo3.src,
        alt: "Logo 3",
      },
      {
        src: logo4.src,
        alt: "Logo 4",
      },
      {
        src: logo8.src,
        alt: "Logo 8",
      },
      {
        src: logo5.src,
        alt: "Logo 5",
      },
      {
        src: logo6.src,
        alt: "Logo 6",
      },
      {
        src: logo2.src,
        alt: "Logo 2",
      },
      {
        src: logo7.src,
        alt: "Logo 7",
      },
    ]}
  />

  <GL />
  <GLPlaces />
</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>
