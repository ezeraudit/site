---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import GalleryText from "../components/GalleryText.astro";
import ImageMarquee from "../components/ImageMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Plans from "../components/Plans.astro";
import Statements from "../components/Statements.astro";
import Introducing from "../components/Introducing.astro";
import GL from "../components/GL.astro";
import GLPlaces from "../components/GlPlaces.astro";

import logo1 from "../assets/astro_transparent.png";
import logo2 from "../assets/azure_transparent.png";
import logo3 from "../assets/bailian_transparent.png";
import logo4 from "../assets/cloudflare_transparent.png";
import logo5 from "../assets/eastmoney_transparent.png";
import logo6 from "../assets/github_transparent.png";
import logo7 from "../assets/huggingface_transparent.png";
import logo8 from "../assets/hugo_transparent.png";
import logo9 from "../assets/openclaw_transparent.png";
import logo10 from "../assets/spaceship_transparent.png";
import logo11 from "../assets/supabase_transparent.png";
import logo12 from "../assets/vercel_transparent.png";

---

<Layout 
  title="对抗式审计级财报分析系统" 
  description="弈泽财报分析 (Ezer Audit) 领先的对抗式审计级财报分析系统。通过红蓝对抗机制，为投资者提供专业级的财务风险挖掘、数据交叉验证和结构化审计报告。"
  keywords="财报分析, 财务审计, 股票投资, 风险检测, 弈泽财报, 审计级AI, 红蓝对抗"
>
  <HeroHome
    title="对抗式 审计级 财报分析"
    subtitle="弈泽将专业研究员的流程系统化，打通「解析-纠察-验证-复核-生成」全链路，助你快速抓住真正的风险点。"
    cta={{
      title: "立即体验",
      url: "/search/?preview=true",
    }}
  />

  <Introducing
    title="弈泽不是普通的财报助手，而是小白也能快速上手的专业分析系统"
    text="针对财报阅读门槛高、模型不可靠、工具不匹配等痛点，弈泽 行业首创红蓝对抗验证逻辑。红队挖掘疑点，蓝队反证校验，解决通用模型“黑盒输出、不可靠”的核心顽疾。"
    cta={{
      title: "开始分析",
      url: "/search/",
    }}
  />

  <StepsTimeline
    title="3步完成专业财报分析"
    items={[
      {
        title: "一键输入",
        text: "输入公司名称或代码，系统快速发起分析，自动调取并解析冗长的财务报告。",
      },
      {
        title: "智能对抗分析",
        text: "自研编排中枢驱动多智能体并行处理，通过红蓝交叉验证，大幅提升疑点覆盖率与分析效率。",
      },
      {
        title: "结构化结论输出",
        text: "自动生成带有风险等级、证据依据和复核建议的报告，分析过程全程可视化、可追溯。",
      },
    ]}
  />

  <GalleryText
    title="专为1.5亿 泛投资人群打造"
    text="简洁的界面下，运行着高度复杂的编排中枢。我们降低了财报研究门槛，让普通投资者也能低成本体验专业级的投研分析能力。"
    cta={{
      title: "查看演示",
      url: "/check/?preview=true",
    }}
    images={[
      {
        alt: "财报风险侦察界面",
        src: "/image-1.jpg",
        width: 6000,
        height: 4000,
      },
      {
        alt: "红蓝对抗验证逻辑",
        src: "/image-2.jpg",
        width: 2689,
        height: 4032,
      },
      {
        alt: "结构化分析报告",
        src: "/image-3.jpg",
        width: 3734,
        height: 5359,
      },
    ]}
    marqueeTexts={[
      "红蓝对抗",
      "结果可验证",
      "多智能体协作",
      "证据链完整",
    ]}
  />

  <Statements
    items={[
      {
        title: "模块化架构",
        text: "自研编排中枢+子智能体集群，各分析模块独立迭代，精准适配复杂的财报审计场景。",
      },
      {
        title: "交叉验证流程",
        text: "行业首创红蓝分工，通过逻辑反证与口径校验，大幅降低单路径推理误判与模型幻觉。",
      },
      {
        title: "可持续商业模式",
        text: "多模型路由策略显著优化成本，保障 B 端交付毛利空间与 C 端普惠服务的持续性。",
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "红蓝对抗",
      "结果可验证",
      "多智能体协作",
      "证据链完整",
    ]}
  />

  <Plans
    title="服务计划"
    subtitle="免费体验专业工具，增值服务解锁深度研究需求。"
    items={[
      {
        title: "免费版",
        price: {
          amount: "￥0",
          duration: "月",
        },
        link: {
          title: "开始使用",
          url: "/check/?preview=true",
        },
        features: [
          { title: "每日3次财报分析" },
          { title: "红蓝对抗分析" },
          { title: "数据交叉验证" },
          { title: "社区支持", disabled: true },
          { title: "导出专业 PDF 报告", disabled: true },
        ],
      },
      {
        title: "高级版",
        price: {
          amount: "￥29.99",
          oldAmount: "￥49.99",
          duration: "月",
        },
        badge: "限时优惠",
        link: {
          title: "立即购买",
          url: "/premium/?from=home",
        },
        features: [
          { title: "无限次财报分析" },
          { title: "红蓝对抗分析" },
          { title: "数据交叉验证" },
          { title: "社区支持" },
          { title: "导出专业 PDF 报告" },
        ],
      },
    ]}
  />

  <Faqs
    title="常见问题"
    mobileTitle="FAQs"
    subtitle="快速了解 弈泽 的核心竞争力。"
    items={[
      {
        question: "弈泽 和通用大模型（如 ChatGPT）分析财报有什么区别？",
        answer:
          "通用大模型缺乏稳定的研究流程且易产生“幻觉”。弈泽 强调编排、验证、证据链与复核建议，结果可追溯、可验证。",
      },
      {
        question: "什么是“红蓝对抗”验证机制？",
        answer:
          "这是行业首创逻辑：红队负责挖掘异常与疑点，蓝队负责反证与口径校验。交叉验证能显著降低误判，确保结论可靠性。",
      },
      {
        question: "Ezer 的核心用户是谁？",
        answer:
          "我们主要服务两类核心客户：一是愿意主动研究财报的活跃个体投资者；二是行情资讯、投研工具、券商等 B 端平台客户。",
      },
      {
        question: "普通投资者真的能看懂分析结论吗？",
        answer:
          "是的。我们的目标就是降低阅读门槛，将长篇累牍的术语转化为带有风险等级和明确证据的结构化报告。",
      },
      {
        question: "项目目前的进度如何？",
        answer:
          "目前已完成 MVP 开发及核心验证，财报上传、智能分析、报告生成等全流程已跑通，具备完整落地可行性。",
      },
    ]}
  />

  <ImageMarquee
    images={[
      {
        src: logo1.src,
        alt: "Logo 1",
      },
      {
        src: logo2.src,
        alt: "Logo 2",
      },
      {
        src: logo3.src,
        alt: "Logo 3",
      },
      {
        src: logo4.src,
        alt: "Logo 4",
      },
      {
        src: logo5.src,
        alt: "Logo 5",
      },
      {
        src: logo6.src,
        alt: "Logo 6",
      },
      {
        src: logo7.src,
        alt: "Logo 7",
      },
      {
        src: logo8.src,
        alt: "Logo 8",
      },
      {
        src: logo9.src,
        alt: "Logo 9",
      },
      {
        src: logo10.src,
        alt: "Logo 10",
      },
      {
        src: logo11.src,
        alt: "Logo 11",
      },
      {
        src: logo12.src,
        alt: "Logo 12",
      },
    ]}
  />

  <GL />
  <GLPlaces />
</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>