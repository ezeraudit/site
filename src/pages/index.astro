</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }

  .model-proof {
    padding: 6rem 0 4rem;
  }

  .model-proof__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(320px, 1fr);
    gap: 3rem;
    align-items: center;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
    }
  }

  .model-proof__eyebrow {
    margin: 0 0 1rem;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    color: var(--color-brand-1);
  }

  .model-proof__title {
    --fs: clamp(2.4rem, 5vw, 4.8rem);
    --lh: 1.05;
    margin-bottom: 1.5rem;
  }

  .model-proof__text {
    max-width: 36rem;
    opacity: 0.78;
  }

  .input-density-card {
    display: grid;
    gap: 1rem;
    padding: clamp(1.4rem, 4vw, 3rem);
    border: 1px solid rgba(var(--rgb-text), 0.1);
    border-radius: 2rem;
    position: relative;
    z-index: 9;
    background: rgba(var(--rgb-white), 0.3);
    backdrop-filter: blur(2px);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.05);

    :global([data-theme="dark"]) & {
      background: rgba(24, 24, 30, 0.3);
    }
  }

  .density-path {
    padding: 1.2rem;
    border: 1px solid rgba(var(--rgb-text), 0.1);
    border-radius: 1.25rem;
    background: rgba(var(--rgb-text), 0.035);
  }

  .density-path.is-ezer {
    border-color: rgba(var(--rgb-brand-1), 0.4);
    background: linear-gradient(135deg, rgba(var(--rgb-brand-1), 0.12), rgba(var(--rgb-brand-2), 0.08));
  }

  .density-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;

    @media (--mq-phone) {
      display: block;
    }
  }

  .density-head strong,
  .density-head em {
    display: block;
  }

  .density-head strong {
    font-size: 1.05rem;
  }

  .density-head em,
  .density-path p,
  .density-note {
    font-size: 0.85rem;
    color: var(--color-text-alt);
  }

  .density-funnel,
  .density-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0;
  }

  .density-funnel span,
  .density-flow span {
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
    font-size: 0.78rem;
    line-height: 1;
  }

  .density-funnel span {
    background: rgba(var(--rgb-text), 0.08);
    color: var(--color-text-alt);
  }

  .density-flow span {
    background: rgba(var(--rgb-brand-1), 0.16);
    color: var(--color-brand-1);
    font-weight: 700;
  }

  .density-meter {
    height: 0.85rem;
    border-radius: 999px;
    background: rgba(var(--rgb-text), 0.08);
    overflow: hidden;
  }

  .density-meter span {
    display: block;
    width: var(--w);
    height: 100%;
    border-radius: inherit;
    transition: width 900ms ease;
  }

  .is-diy .density-meter span {
    background: rgba(var(--rgb-text), 0.32);
  }

  .is-ezer .density-meter span {
    background: linear-gradient(90deg, var(--color-brand-1), var(--color-brand-2));
  }

  .density-path p,
  .density-note {
    margin: 0.75rem 0 0;
  }
</style>
