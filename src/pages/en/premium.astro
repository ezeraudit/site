---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout 
  title={t('nav.premium')}
  description="Join Ezer Audit Premium to unlock unlimited deep analyses, professional PDF exports, and advanced financial metrics."
  keywords="premium subscription, unlimited analysis, audit PDF export, professional investment tools"
>
  <div class="premium-container">
    <div class="background-glow"></div>
    
    <div class="content-wrapper">
      <h1 class="premium-title fade-in-up">Premium</h1>
      <p class="description fade-in-up delay-1">
        {t('premium.desc')}
      </p>
      
      <div class="waitlist-card fade-in-up delay-3">
        <div class="discount-tag">{t('premium.off_tag')}</div>
        <h3>{t('premium.waitlist_title')}</h3>
        <p>{t('premium.waitlist_subtitle')}</p>
        
        <div class="form-group">
          <button id="join-waitlist-btn" class="primary-btn">
            <span class="btn-text">{t('premium.join_waitlist')}</span>
            <span class="loader hidden"></span>
          </button>
        </div>
        <p id="user-display-email" class="user-email-hint hidden"></p>
        <p id="message" class="message hidden"></p>
      </div>

      <div class="features-grid fade-in-up delay-4">
        <div class="feature-item">
          <div class="icon">🚀</div>
          <h4>{t('premium.feature_unlimited_title')}</h4>
          <p>{t('premium.feature_unlimited_desc')}</p>
        </div>
        <div class="feature-item">
          <div class="icon">📊</div>
          <h4>{t('premium.feature_metrics_title')}</h4>
          <p>{t('premium.feature_metrics_desc')}</p>
        </div>
        <div class="feature-item">
          <div class="icon">📄</div>
          <h4>{t('premium.feature_pdf_title')}</h4>
          <p>{t('premium.feature_pdf_desc')}</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .premium-container {
    min-height: 100vh;
    padding: 10rem 2rem 6rem;
    position: relative;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--color-bg);
  }

  .background-glow {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(var(--rgb-brand-1), 0.12) 0%, transparent 70%);
    filter: blur(80px);
    z-index: 0;
    pointer-events: none;
  }

  .content-wrapper {
    max-width: 1000px;
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .premium-badge {
    display: inline-block;
    padding: 0.6rem 1.8rem;
    background: rgba(var(--rgb-brand-1), 0.1);
    color: var(--color-brand-1);
    border-radius: 100px;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 2rem;
    border: 1.5px solid rgba(var(--rgb-brand-1), 0.2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .premium-title {
    font-size: clamp(3.5rem, 12vw, 6.5rem);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 2rem;
    color: var(--color-text);
    background: linear-gradient(to bottom, var(--color-text) 60%, rgba(var(--rgb-text), 0.6));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.04em;
    display: block;
  }

  .description {
    font-size: 1.4rem;
    color: var(--color-text-alt);
    margin-bottom: 4rem;
    line-height: 1.6;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .waitlist-card {
    background: var(--color-surface);
    border: 1px solid rgba(var(--rgb-brand-1), 0.2);
    border-radius: 32px;
    padding: 4rem 3rem;
    margin-bottom: 5rem;
    position: relative;
    box-shadow: 0 30px 60px -10px rgba(0, 0, 0, 0.15);
  }

  .discount-tag {
    position: absolute;
    top: -15px;
    right: 30px;
    background: var(--color-brand-1);
    color: white;
    padding: 0.4rem 1.2rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 900;
    box-shadow: 0 6px 20px rgba(var(--rgb-brand-1), 0.4);
    transform: rotate(2deg);
  }

  .waitlist-card h3 {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .waitlist-card p {
    font-size: 1.1rem;
    color: var(--color-text-alt);
    margin-bottom: 2.5rem;
  }

  .form-group {
    display: flex;
    justify-content: center;
    margin: 0 auto;
  }

  .user-email-hint {
    margin-top: 1.5rem;
    font-size: 0.95rem;
    color: var(--color-text-alt);
    font-weight: 500;
  }

  .primary-btn {
    background: var(--color-brand-1);
    color: white;
    border: none;
    border-radius: 16px;
    padding: 1.2rem 4rem;
    font-weight: 700;
    font-size: 1.25rem;
    cursor: pointer;
    transition: all 0.3s var(--ease-out-expo);
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 280px;
    box-shadow: 0 10px 30px rgba(var(--rgb-brand-1), 0.3);
  }

  .primary-btn:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 15px 40px rgba(var(--rgb-brand-1), 0.4);
    filter: brightness(1.1);
  }

  .primary-btn:active {
    transform: translateY(-2px);
  }

  .primary-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .feature-item {
    text-align: left;
    padding: 2.5rem;
    background: rgba(var(--rgb-brand-1), 0.03);
    border-radius: 24px;
    border: 1.5px solid rgba(var(--rgb-brand-1), 0.08);
    transition: all 0.4s ease;
  }

  .feature-item:hover {
    background: rgba(var(--rgb-brand-1), 0.06);
    border-color: rgba(var(--rgb-brand-1), 0.2);
    transform: translateY(-5px);
  }

  .feature-item .icon {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .feature-item h4 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .feature-item p {
    font-size: 1rem;
    color: var(--color-text-alt);
    line-height: 1.6;
  }

  .message {
    margin-top: 2rem;
    font-size: 1rem;
    padding: 1rem;
    border-radius: 12px;
    font-weight: 600;
  }

  .message.success {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .message.error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .hidden {
    display: none !important;
  }

  .loader {
    width: 24px;
    height: 24px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: white;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Animations */
  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s var(--ease-out-expo) forwards;
  }

  .delay-1 { animation-delay: 0.15s; }
  .delay-2 { animation-delay: 0.3s; }
  .delay-3 { animation-delay: 0.45s; }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .premium-container {
      padding-top: 8rem;
    }

    .premium-title {
      font-size: 3.5rem;
    }
  }

  @media (max-width: 640px) {
    .premium-container {
      padding: 6rem 1rem 4rem;
    }

    .premium-title {
      font-size: 2.8rem;
      margin-bottom: 1.5rem;
    }

    .description {
      font-size: 1.1rem;
      margin-bottom: 2.5rem;
      padding: 0 1rem;
    }

    .waitlist-card {
      padding: 3rem 1.5rem;
      border-radius: 24px;
      margin-bottom: 3rem;
    }

    .discount-tag {
      right: 20px;
      padding: 0.3rem 0.8rem;
      font-size: 0.8rem;
    }

    .waitlist-card h3 {
      font-size: 1.8rem;
    }

    .primary-btn {
      width: 100%;
      min-width: 0;
      padding: 1rem 2rem;
      font-size: 1.1rem;
    }

    .feature-item {
      padding: 1.5rem;
    }

    .feature-item .icon {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .feature-item h4 {
      font-size: 1.2rem;
    }
  }
</style>

<script is:inline define:vars={{ 
  t_success: t('premium.waitlist_success'), 
  t_error: t('premium.waitlist_error'),
  t_signin: t('premium.signin_first'),
  lang
}}>
  async function initPremiumPage() {
    const joinBtn = document.getElementById('join-waitlist-btn');
    const btnText = joinBtn.querySelector('.btn-text');
    const loader = joinBtn.querySelector('.loader');
    const messageEl = document.getElementById('message');
    const emailHint = document.getElementById('user-display-email');

    const session = await window.auth?.getSession();
    if (session) {
      const hintPrefix = lang === 'en' ? 'Joining as: ' : '加入身份：';
      emailHint.textContent = `${hintPrefix}${session.user.email}`;
      emailHint.classList.remove('hidden');
    } else {
      joinBtn.disabled = true;
      btnText.textContent = t_signin;
      return;
    }

    joinBtn.addEventListener('click', async () => {
      joinBtn.disabled = true;
      btnText.classList.add('hidden');
      loader.classList.remove('hidden');
      messageEl.classList.add('hidden');

      try {
        const { error } = await window.auth.client
          .from('waitlist')
          .insert({
            uid: session.user.id,
            email: session.user.email
          });

        if (error) {
          if (error.code === '23505') {
            const alreadyMsg = lang === 'en' ? "You're already on the waitlist!" : "您已在等候名单中！";
            messageEl.textContent = alreadyMsg;
            messageEl.className = 'message success';
          } else {
            throw error;
          }
        } else {
          messageEl.textContent = t_success;
          messageEl.className = 'message success';
        }
      } catch (err) {
        console.error('Waitlist error:', err);
        messageEl.textContent = t_error;
        messageEl.className = 'message error';
      } finally {
        btnText.classList.remove('hidden');
        loader.classList.add('hidden');
        messageEl.classList.remove('hidden');
        joinBtn.disabled = false;
      }
    });
  }

  initPremiumPage();
  document.addEventListener('astro:after-swap', initPremiumPage);
</script>
