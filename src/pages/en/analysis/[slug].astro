---
import Layout from "../../../layouts/Layout.astro";
import { Redis } from '@upstash/redis';
import { sampleData } from "../../../data/sampleData";

export const prerender = false; // SSR mode

const { slug } = Astro.params;

// 1. Handle Preview
let data;
let code = "";
let year = "";
let period = "";
const lang = 'en';

const kvRestUrl = import.meta.env.UPSTASH_REDIS_KV_REST_API_URL;
const kvRestToken = import.meta.env.UPSTASH_REDIS_KV_REST_API_TOKEN;

// Initialize KV if credentials exist
const kv = (kvRestUrl && kvRestToken) ? new Redis({ url: kvRestUrl, token: kvRestToken }) : null;

if (slug === 'preview') {
  data = sampleData;
  code = "601899.SH";
  year = "2024";
  period = "FY";
} else {
  const parts = slug?.split('-') || [];
  if (parts.length < 3) return new Response(null, { status: 404 });
  code = parts[0].replace('_', '.');
  year = parts[1];
  period = parts[2];
  
  const redisPeriod = period === 'FY' ? 'full' : period;
  const cacheKey = `cache:check:${code}:${year}:${redisPeriod}:${lang}`;
  data = kv ? await kv.get<any[] | null>(cacheKey) : null;
}

// 2. Ensure data is valid array
if (!data || !Array.isArray(data)) {
  return new Response('Analysis document is being generated, expired, or data format is invalid.', { 
    status: 503,
    headers: { 'Retry-After': '3600' }
  });
}

// 3. Dynamic Data Extraction
const a_data = data.find(i => i.event === 'a_normalized')?.data || {};
const final_result = data.find(i => i.event === 'final_result')?.data || {};

const companyName = a_data.company?.name || code;
const reportType = period === 'FY' ? 'Annual Report' : period;
const pageTitle = `${companyName} ${year} ${reportType} Analysis`;

// Helper for safe display
const formatValue = (val: any) => {
  if (val === null || val === undefined || isNaN(val)) return null;
  return val;
};

const displayMetrics = [
  { label: 'Revenue', value: formatValue(a_data.income_statement?.revenue), unit: 'B', div: 1e8 },
  { label: 'Net Profit', value: formatValue(a_data.income_statement?.net_profit), unit: 'B', div: 1e8 },
  { label: 'Gross Margin', value: formatValue(a_data.income_statement?.gross_margin), unit: '%', div: 1 },
  { label: 'ROE', value: formatValue(a_data.key_ratios?.roe), unit: '%', div: 1 }
].filter(m => m.value !== null);

const seoMetricsStr = displayMetrics.map(m => {
  const displayVal = m.unit === 'B' ? (m.value / 1e8).toFixed(2) + 'B' : m.value + m.unit;
  return `${m.label}: ${displayVal}`;
}).join(', ');

const seoDescription = `Detailed analysis of ${companyName} (${code}) ${year} ${reportType}. ${seoMetricsStr}. Ezer reveals the financial truth through historical records, cross-validation, and audit-grade risk assessment.`;

const checkUrl = slug === 'preview' ? '/en/check?preview=true' : `/en/check?code=${code}&year=${year}&period=${period === 'FY' ? 'full' : period}`;

// Match check.astro exactly: prefix + raw value
const displayStatus = final_result.final_status || final_result.status || final_result.result || '';
const finalPrefix = 'Final Result: ';
---

<Layout 
  title={pageTitle}
  description={seoDescription}
>
  <div class="check-page">
    <div class="u-container">
      <!-- Page Header -->
      <div class="check-header">
        <h1 class="check-title">{companyName} {year} {reportType} Analysis</h1>
      </div>

      <div class="results-container">
        <!-- Stats Preview (Dynamic) -->
        {displayMetrics.length > 0 && (
          <div class="stats-preview-grid">
            {displayMetrics.map(m => (
              <div class="stat-box">
                <span class="stat-label">{m.label}</span>
                <span class="stat-value">
                  {m.unit === 'B' ? (m.value / 1e8).toFixed(2) + 'B' : m.value + m.unit}
                </span>
              </div>
            ))}
          </div>
        )}

        <!-- CTA Box -->
        <div class="thought-container">
          <div class="thought-header">
            <span class="thought-icon">📊</span>
            <span class="thought-title">Detailed Analysis & Evidence</span>
          </div>
          <div class="cta-inner">
             <a href={checkUrl} class="primary-cta-btn" rel="nofollow">Click to View</a>
          </div>
        </div>

        <!-- Summary Section -->
        <div class="summary-container">
          <h2 class="col-title">Key Conclusion</h2>
          <div class="summary-box">
            <div class="text-output">
               {final_result.summary}
            </div>
            {displayStatus && (
              <div class="final-result-output">
                {finalPrefix}{displayStatus}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .u-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .check-page {
    min-height: 100vh;
    padding: 10vh 0 4rem;
    background: var(--color-bg);
  }

  .check-header { text-align: center; margin-bottom: 2.5rem; }
  .check-title { 
    font-family: var(--font-roboto-slab); 
    font-size: clamp(1.4rem, 3.5vw, 2.4rem); 
    font-weight: 800;
  }

  .stats-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .stat-box {
    background: var(--color-surface);
    border: 1px solid rgba(var(--rgb-brand-1), 0.1);
    padding: 1.2rem;
    border-radius: 12px;
    text-align: center;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-alt);
    margin-bottom: 0.4rem;
    display: block;
    opacity: 0.8;
  }

  .stat-value {
    font-family: var(--font-mono, monospace);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-brand-1);
    letter-spacing: -0.02em;
  }

  .results-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .thought-container {
    background: var(--color-surface);
    border: 1px solid rgba(var(--rgb-brand-1), 0.15);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .thought-header {
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(var(--rgb-brand-1), 0.03);
    border-bottom: 1px solid rgba(var(--rgb-brand-1), 0.1);
    justify-content: center;
  }

  .thought-title {
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--color-brand-1);
  }

  .cta-inner {
    padding: 2.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .primary-cta-btn {
    display: inline-block;
    background: var(--color-brand-1);
    color: #fff;
    padding: 0.8rem 3.5rem;
    border-radius: 20px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s;
    box-shadow: 0 4px 15px rgba(var(--rgb-brand-1), 0.2);
  }
  .primary-cta-btn:hover { transform: scale(1.04); filter: brightness(1.1); }

  .summary-container { padding-bottom: 2rem; }
  .col-title { 
    font-size: 1.1rem; font-weight: 700; color: var(--color-text-alt); 
    text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.8rem;
  }
  .summary-box {
    background: var(--color-surface);
    border: 2px solid var(--color-brand-1);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    box-shadow: 0 4px 24px rgba(var(--rgb-brand-1), 0.12);
  }
  .text-output { font-size: 0.95rem; line-height: 1.7; color: var(--color-text); opacity: 0.95; }
  .final-result-output {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px dashed rgba(var(--rgb-brand-1), 0.2);
    font-weight: 600;
    color: var(--color-brand-1);
    font-size: 1.1rem;
  }

  @media (max-width: 640px) {
    .u-container { padding: 0 1rem; }
  }
</style>
